---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ShareModal from '../components/ShareModal.astro';

interface AdjacentPost {
	title: string;
	slug:  string;
}

interface Props {
	title:        string;
	description:  string;
	pubDate:      Date;
	updatedDate?: Date;
	heroImage?:   string;
	bodyHtml?:    string;
	prevPost?:    AdjacentPost | null;
	nextPost?:    AdjacentPost | null;
}

const { title, description, pubDate, updatedDate, heroImage, bodyHtml, prevPost, nextPost } = Astro.props;

const wordCount = bodyHtml ? bodyHtml.replace(/<[^>]+>/g, ' ').split(/\s+/).filter(Boolean).length : 0;
const readingTime = Math.ceil(wordCount / 200) || 1;

const formattedDate = pubDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const formattedUpdated = updatedDate?.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			.prose {
				width: 720px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 3rem 1rem 4rem;
			}

			.post-header {
				margin-bottom: 2rem;
			}

			.post-title {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 2.5rem;
				font-weight: 700;
				color: var(--text);
				line-height: 1.15;
				margin: 0 0 1rem 0;
			}

			.post-meta {
				display: flex;
				align-items: center;
				gap: 1rem;
				font-family: 'JetBrains Mono', monospace;
				font-size: 14px;
				color: var(--text-muted);
				flex-wrap: wrap;
			}

			.post-meta span::before {
				content: '·';
				margin-right: 1rem;
			}

			.post-meta span:first-child::before {
				content: none;
			}

			.last-updated {
				display: block;
				font-style: italic;
				color: var(--text-muted);
				font-family: inherit;
				font-size: 14px;
				margin-top: 0.5rem;
			}

			.divider {
				border: none;
				border-top: 1px solid var(--border);
				margin: 1.5rem 0 2rem;
			}

			.hero-image {
				margin-bottom: 2rem;
			}

			.hero-image img {
				width: 100%;
				height: auto;
				border-radius: 6px;
			}

			.post-nav {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid var(--border);
			}

			.post-nav-link {
				display: flex;
				flex-direction: column;
				gap: 0.375rem;
				text-decoration: none;
				padding: 1rem 1.25rem;
				border: 1px solid var(--border);
				border-radius: 8px;
				transition: border-color 0.15s;
			}

			.post-nav-link:hover {
				border-color: var(--accent);
			}

			.post-nav-next {
				grid-column: 2;
				text-align: right;
				align-items: flex-end;
			}

			.post-nav-label {
				font-family: 'JetBrains Mono', monospace;
				font-size: 11px;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent);
			}

			.post-nav-title {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 0.9375rem;
				font-weight: 500;
				color: var(--text);
				line-height: 1.4;
			}

			@media (max-width: 560px) {
				.post-nav {
					grid-template-columns: 1fr;
				}

				.post-nav-next {
					grid-column: 1;
					text-align: left;
					align-items: flex-start;
				}
			}

			#read-progress {
				position: fixed;
				top: 0;
				left: 0;
				height: 2px;
				background: var(--accent);
				z-index: 9999;
				width: 0%;
				transition: width 0.08s linear;
			}

			@media (max-width: 640px) {
				.post-title {
					font-size: 1.875rem;
				}
			}
		</style>
	</head>

	<body>
		<div id="read-progress" aria-hidden="true"></div>
		<Header />
		<main style="padding: 0; max-width: 100%; width: 100%;">
			<article>
				<div class="prose">
					<div class="post-header">
						<h1 class="post-title">{title}</h1>
						<div class="post-meta">
							<span>{formattedDate}</span>
							<span>{readingTime} min read</span>
							<span class="share-slot"><ShareModal title={title} image={heroImage} /></span>
						</div>
						{updatedDate && (
							<span class="last-updated">Last updated on {formattedUpdated}</span>
						)}
					</div>

					{heroImage && (
						<div class="hero-image">
							<img src={heroImage} alt="" width="720" height="360" />
						</div>
					)}

					<hr class="divider" />
					{bodyHtml ? <div set:html={bodyHtml} /> : <slot />}

					{(prevPost || nextPost) && (
						<nav class="post-nav">
							{prevPost ? (
								<a class="post-nav-link post-nav-prev" href={`/blog/${prevPost.slug}/`}>
									<span class="post-nav-label">← Older</span>
									<span class="post-nav-title">{prevPost.title}</span>
								</a>
							) : <span />}
							{nextPost && (
								<a class="post-nav-link post-nav-next" href={`/blog/${nextPost.slug}/`}>
									<span class="post-nav-label">Newer →</span>
									<span class="post-nav-title">{nextPost.title}</span>
								</a>
							)}
						</nav>
					)}
				</div>
			</article>
		</main>
		<Footer />
		<script>
			// Every post uses this same layout/script — the module only executes
			// once (cached per URL), so astro:page-load re-runs this on every
			// View Transitions navigation to track whichever post is now showing.
			document.addEventListener('astro:page-load', () => {
				(window as any).__readProgressCleanup?.();

				const bar = document.getElementById('read-progress') as HTMLDivElement | null;
				if (!bar) return;

				function updateProgress() {
					const article = document.querySelector('article');
					if (!article || !bar) return;
					const { top, height } = article.getBoundingClientRect();
					const scrolled = Math.max(0, -top);
					const total = height - window.innerHeight;
					bar.style.width = total > 0 ? Math.min(100, (scrolled / total) * 100) + '%' : '0%';
				}
				window.addEventListener('scroll', updateProgress, { passive: true });
				updateProgress();

				(window as any).__readProgressCleanup = () => {
					window.removeEventListener('scroll', updateProgress);
				};
			});
		</script>
	</body>
</html>
