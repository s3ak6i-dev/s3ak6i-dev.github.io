---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { getBlogPosts } from '../../lib/contentful';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = await getBlogPosts();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.blog-listing {
				width: 960px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 3rem 1rem 4rem;
			}

			.page-header {
				display: flex;
				align-items: flex-start;
				justify-content: space-between;
				gap: 1.5rem;
				margin-bottom: 2.5rem;
			}

			.page-header-text h1 {
				font-size: 2rem;
				margin-bottom: 0.5rem;
			}

			.blog-subtitle {
				color: var(--text-muted);
				font-size: 1rem;
				margin: 0;
			}

			.page-gif {
				width: 140px;
				flex-shrink: 0;
				border-radius: 8px;
				overflow: hidden;
			}

			.page-gif img {
				display: block;
				width: 100%;
				height: auto;
			}

			@media (max-width: 560px) {
				.page-gif { width: 100px; }
			}

			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.post-item {
				border-top: 1px solid var(--border);
				padding: 1.25rem 0;
				position: relative;
			}

			.post-item:last-child {
				border-bottom: 1px solid var(--border);
			}

			.post-item-inner {
				display: flex;
				gap: 1rem;
				align-items: flex-start;
				padding-left: 0;
				border-left: 2px solid transparent;
				transition: border-color 0.15s, padding-left 0.15s;
			}

			.post-item:hover .post-item-inner {
				border-left-color: var(--accent);
				padding-left: 0.75rem;
			}

			.post-thumb {
				width: 88px;
				height: 62px;
				flex-shrink: 0;
				border-radius: 4px;
				overflow: hidden;
				background: var(--surface-2);
				border: 1px solid var(--border);
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.post-thumb img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.post-thumb-default {
				width: 22px;
				height: 22px;
				opacity: 0.2;
			}

			.post-content {
				flex: 1;
				min-width: 0;
			}

			.post-meta-row {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
				margin-bottom: 0.375rem;
			}

			.post-title {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 1.0625rem;
				font-weight: 500;
				color: var(--accent);
				text-decoration: none;
				transition: color 0.15s;
			}

			.post-item:hover .post-title {
				color: var(--text);
			}

			.post-date {
				font-family: 'JetBrains Mono', monospace;
				font-size: 13px;
				color: var(--text-muted);
				white-space: nowrap;
				flex-shrink: 0;
			}

			.post-description {
				font-size: 0.9375rem;
				color: var(--text-muted);
				margin: 0;
				line-height: 1.5;
			}

			@media (max-width: 520px) {
				.post-thumb {
					width: 64px;
					height: 48px;
				}

				.post-meta-row {
					flex-direction: column;
					gap: 0.125rem;
				}

				.post-date {
					font-size: 12px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main style="padding: 0; max-width: 100%; width: 100%;">
			<div class="blog-listing">
				<div class="page-header">
					<div class="page-header-text">
						<h1>Writing</h1>
						<p class="blog-subtitle">Notes on AI, systems, and building things.</p>
					</div>
					<div class="page-gif">
						<img src="https://media1.tenor.com/m/796hzQFEHqoAAAAC/uy-rick-y-morty.gif" alt="Rick and Morty" />
					</div>
				</div>

				<ul class="post-list">
					{
						posts.map((post) => {
							const dateStr = new Date(post.pubDate).toLocaleDateString('en-US', {
								year: 'numeric',
								month: 'short',
								day: 'numeric',
							});
							return (
								<li class="post-item">
									<div class="post-item-inner">
										<a href={`/blog/${post.slug}/`} class="post-thumb" tabindex="-1" aria-hidden="true">
											{post.heroImage ? (
												<img src={post.heroImage} alt="" />
											) : (
												<svg class="post-thumb-default" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
													<rect x="3" y="3" width="18" height="18" rx="2"/>
													<path d="M3 9h18M9 21V9"/>
												</svg>
											)}
										</a>
										<div class="post-content">
											<div class="post-meta-row">
												<a class="post-title" href={`/blog/${post.slug}/`}>
													{post.title}
												</a>
												<span class="post-date">{dateStr}</span>
											</div>
											{post.description && (
												<p class="post-description">{post.description}</p>
											)}
										</div>
									</div>
								</li>
							);
						})
					}
				</ul>
			</div>
		</main>
		<Footer />
	</body>
</html>
