---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Uses — ${SITE_TITLE}`}
			description="The tools, languages, and infrastructure Surya Krishna uses day to day."
		/>
		<style>
			.page {
				width: 720px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 3rem 1rem 5rem;
			}

			.page-heading {
				font-size: 2rem;
				margin-bottom: 0.375rem;
			}

			.page-sub {
				color: var(--text-muted);
				font-size: 1rem;
				margin-bottom: 3rem;
			}

			.section {
				margin-bottom: 2.75rem;
			}

			.section-label {
				font-family: 'JetBrains Mono', monospace;
				font-size: 11px;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--accent);
				margin-bottom: 1rem;
			}

			.uses-list {
				list-style: none;
				padding: 0;
				margin: 0;
				border-top: 1px solid var(--border);
			}

			.uses-item {
				display: grid;
				grid-template-columns: 160px 1fr;
				gap: 1rem;
				padding: 0.875rem 0;
				border-bottom: 1px solid var(--border);
				align-items: baseline;
			}

			.uses-key {
				font-family: 'JetBrains Mono', monospace;
				font-size: 13px;
				color: var(--text-muted);
				flex-shrink: 0;
			}

			.uses-val {
				font-size: 0.9375rem;
				color: var(--text);
				line-height: 1.55;
			}

			.uses-val a {
				color: var(--accent);
			}

			.uses-val a:hover {
				color: var(--accent-dim);
			}

			/* Tag chips for tooling */
			.tag-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.375rem;
			}

			.tag {
				font-family: 'JetBrains Mono', monospace;
				font-size: 11.5px;
				color: var(--text-muted);
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 4px;
				padding: 2px 8px;
			}

			@media (max-width: 560px) {
				.uses-item {
					grid-template-columns: 1fr;
					gap: 0.25rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main style="padding: 0; max-width: 100%; width: 100%;">
			<div class="page">
				<h1 class="page-heading">Uses</h1>
				<p class="page-sub">Tools I actually use. Updated when things change.</p>

				<!-- Languages -->
				<section class="section">
					<p class="section-label">Languages</p>
					<ul class="uses-list">
						<li class="uses-item">
							<span class="uses-key">Primary</span>
							<span class="uses-val">
								<div class="tag-row">
									<span class="tag">Python</span>
									<span class="tag">TypeScript</span>
								</div>
							</span>
						</li>
						<li class="uses-item">
							<span class="uses-key">Also</span>
							<span class="uses-val">
								<div class="tag-row">
									<span class="tag">JavaScript</span>
									<span class="tag">Java</span>
								</div>
							</span>
						</li>
					</ul>
				</section>

				<!-- AI & ML -->
				<section class="section">
					<p class="section-label">AI / ML</p>
					<ul class="uses-list">
						<li class="uses-item">
							<span class="uses-key">Frameworks</span>
							<span class="uses-val">
								<div class="tag-row">
									<span class="tag">TensorFlow</span>
									<span class="tag">Keras</span>
									<span class="tag">Scikit-Learn</span>
									<span class="tag">ONNX Runtime</span>
								</div>
							</span>
						</li>
						<li class="uses-item">
							<span class="uses-key">Models</span>
							<span class="uses-val">
								<div class="tag-row">
									<span class="tag">CNN</span>
									<span class="tag">LSTM</span>
									<span class="tag">BiLSTM</span>
									<span class="tag">LightGBM</span>
									<span class="tag">CTGAN</span>
									<span class="tag">TVAE</span>
								</div>
							</span>
						</li>
						<li class="uses-item">
							<span class="uses-key">Agents & LLMs</span>
							<span class="uses-val">
								<div class="tag-row">
									<span class="tag">Claude API</span>
									<span class="tag">Claude Code</span>
									<span class="tag">LangChain</span>
									<span class="tag">Mem0</span>
									<span class="tag">Groq</span>
									<span class="tag">OpenAI</span>
								</div>
							</span>
						</li>
					</ul>
				</section>

				<!-- Web & Backend -->
				<section class="section">
					<p class="section-label">Web & Backend</p>
					<ul class="uses-list">
						<li class="uses-item">
							<span class="uses-key">Frontend</span>
							<span class="uses-val">
								<div class="tag-row">
									<span class="tag">Next.js 15</span>
									<span class="tag">React 18/19</span>
									<span class="tag">Expo</span>
								</div>
							</span>
						</li>
						<li class="uses-item">
							<span class="uses-key">Backend</span>
							<span class="uses-val">
								<div class="tag-row">
									<span class="tag">FastAPI</span>
									<span class="tag">WebSockets</span>
									<span class="tag">SSE</span>
								</div>
							</span>
						</li>
						<li class="uses-item">
							<span class="uses-key">Databases</span>
							<span class="uses-val">
								<div class="tag-row">
									<span class="tag">PostgreSQL</span>
									<span class="tag">Neon</span>
									<span class="tag">Supabase</span>
									<span class="tag">MongoDB</span>
									<span class="tag">Drizzle ORM</span>
									<span class="tag">SQLAlchemy</span>
								</div>
							</span>
						</li>
					</ul>
				</section>

				<!-- Infrastructure -->
				<section class="section">
					<p class="section-label">Infrastructure</p>
					<ul class="uses-list">
						<li class="uses-item">
							<span class="uses-key">Deploy</span>
							<span class="uses-val">
								<div class="tag-row">
									<span class="tag">Vercel</span>
									<span class="tag">Railway</span>
									<span class="tag">AWS</span>
									<span class="tag">Azure</span>
								</div>
							</span>
						</li>
						<li class="uses-item">
							<span class="uses-key">DevOps</span>
							<span class="uses-val">
								<div class="tag-row">
									<span class="tag">Docker</span>
									<span class="tag">Nginx</span>
									<span class="tag">GitHub Actions</span>
								</div>
							</span>
						</li>
						<li class="uses-item">
							<span class="uses-key">Storage</span>
							<span class="uses-val">
								<div class="tag-row">
									<span class="tag">Cloudflare R2</span>
									<span class="tag">Supabase Storage</span>
								</div>
							</span>
						</li>
					</ul>
				</section>

				<!-- This site -->
				<section class="section">
					<p class="section-label">This site</p>
					<ul class="uses-list">
						<li class="uses-item">
							<span class="uses-key">Framework</span>
							<span class="uses-val">Astro — static, fast, no JS unless needed</span>
						</li>
						<li class="uses-item">
							<span class="uses-key">Fonts</span>
							<span class="uses-val">Space Grotesk · Inter · JetBrains Mono</span>
						</li>
						<li class="uses-item">
							<span class="uses-key">Hosting</span>
							<span class="uses-val">GitHub Pages via Actions</span>
						</li>
						<li class="uses-item">
							<span class="uses-key">Styling</span>
							<span class="uses-val">Plain CSS — no Tailwind, no component libraries</span>
						</li>
					</ul>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>
