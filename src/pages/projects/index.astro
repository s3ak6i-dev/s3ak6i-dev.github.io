---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import { getProjects, getCaseStudies } from '../../lib/contentful';
import { SITE_TITLE } from '../../consts';

const projects     = await getProjects();
const caseStudies  = await getCaseStudies();

const ANGLES = [
  { key: 'product',      label: 'Product' },
  { key: 'technical',    label: 'Technical' },
  { key: 'business',     label: 'Business' },
  { key: 'socialImpact', label: 'Social Impact' },
] as const;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Projects — ${SITE_TITLE}`}
			description="Things I've built — AI systems, tools, and experiments."
		/>
		<style>
			.page {
				width: 960px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 3rem 1rem 5rem;
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.25rem;
			}

			.card {
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 8px;
				overflow: hidden;
				text-decoration: none;
				display: flex;
				flex-direction: column;
				transition: border-color 0.15s, transform 0.15s;
			}

			.card:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
			}

			.card-thumb {
				width: 100%;
				aspect-ratio: 16 / 9;
				background: var(--surface-2);
				overflow: hidden;
				display: flex;
				align-items: center;
				justify-content: center;
				border-bottom: 1px solid var(--border);
			}

			.card-thumb img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.card-thumb-default {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.5rem;
				color: var(--text-muted);
				opacity: 0.3;
			}

			.card-thumb-default svg {
				width: 32px;
				height: 32px;
			}

			.card-body {
				padding: 1.125rem 1.25rem 1.25rem;
				display: flex;
				flex-direction: column;
				flex: 1;
			}

			.card-top {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 0.5rem;
				margin-bottom: 0.5rem;
			}

			.card-name {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 1rem;
				font-weight: 500;
				color: var(--text);
				line-height: 1.3;
			}

			.card-year {
				font-family: 'JetBrains Mono', monospace;
				font-size: 12px;
				color: var(--text-muted);
				white-space: nowrap;
				flex-shrink: 0;
				margin-top: 2px;
			}

			.card-desc {
				font-size: 0.9rem;
				color: var(--text-muted);
				line-height: 1.55;
				margin: 0 0 1rem 0;
				flex: 1;
			}

			.card-footer {
				display: flex;
				flex-wrap: wrap;
				gap: 0.375rem;
				align-items: center;
				justify-content: space-between;
			}

			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.375rem;
			}

			.tag {
				font-family: 'JetBrains Mono', monospace;
				font-size: 11px;
				color: var(--text-muted);
				background: var(--surface-2);
				border: 1px solid var(--border);
				border-radius: 4px;
				padding: 1px 7px;
			}

			.status-badge {
				font-family: 'JetBrains Mono', monospace;
				font-size: 11px;
				padding: 1px 8px;
				border-radius: 4px;
				border: 1px solid var(--border);
				flex-shrink: 0;
			}

			.status-active {
				color: #4ade80;
				border-color: #4ade8040;
				background: #4ade8010;
			}

			.status-completed {
				color: var(--text-muted);
			}

			.status-archived {
				color: var(--text-muted);
				opacity: 0.6;
			}

			@media (max-width: 640px) {
				.grid { grid-template-columns: 1fr; }
			}

			/* Tabs */
			.tabs {
				display: flex;
				gap: 0.25rem;
				margin-bottom: 2.5rem;
				border-bottom: 1px solid var(--border);
			}

			.tab {
				font-family: 'JetBrains Mono', monospace;
				font-size: 12px;
				letter-spacing: 0.08em;
				color: var(--text-muted);
				background: none;
				border: none;
				border-bottom: 2px solid transparent;
				padding: 0.5rem 1rem;
				cursor: pointer;
				margin-bottom: -1px;
				transition: color 0.15s, border-color 0.15s;
			}

			.tab:hover { color: var(--text); }

			.tab.active {
				color: var(--accent);
				border-bottom-color: var(--accent);
			}

			/* Case study listing */
			.cs-list {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.cs-card {
				display: block;
				text-decoration: none;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 8px;
				padding: 1.5rem;
				transition: border-color 0.15s;
				position: relative;
			}

			.cs-card:hover { border-color: var(--accent); }

			.cs-card-top {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 0.5rem;
			}

			.cs-title {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 1.0625rem;
				font-weight: 500;
				color: var(--text);
			}

			.cs-year {
				font-family: 'JetBrains Mono', monospace;
				font-size: 12px;
				color: var(--text-muted);
			}

			.cs-summary {
				font-size: 0.9375rem;
				color: var(--text-muted);
				line-height: 1.6;
				margin: 0 0 1rem;
			}

			.cs-footer {
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.cs-angles {
				display: flex;
				flex-wrap: wrap;
				gap: 0.375rem;
			}

			.cs-angle {
				font-family: 'JetBrains Mono', monospace;
				font-size: 10px;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--accent);
				background: rgba(232,96,44,0.08);
				border: 1px solid rgba(232,96,44,0.2);
				border-radius: 4px;
				padding: 2px 7px;
			}

			.cs-read {
				font-family: 'JetBrains Mono', monospace;
				font-size: 12px;
				color: var(--accent);
			}

			.cs-empty {
				font-family: 'JetBrains Mono', monospace;
				font-size: 13px;
				color: var(--text-muted);
				padding: 3rem 0;
				text-align: center;
			}
		</style>
	</head>
	<body>
		<Header />
		<PageHero
			title="Projects"
			subtitle="Things I've built — AI systems, tools, and experiments."
			gifSrc="https://media1.tenor.com/m/cUDKyJkDr6kAAAAd/iron-man-iron-man-hammer.gif"
			gifAlt="Tyler Durden"
		/>
		<main style="padding: 0; max-width: 100%; width: 100%;">
			<div class="page">

				<div class="tabs">
					<button class="tab active" data-tab="projects">Projects</button>
					<button class="tab" data-tab="case-studies">Case Studies</button>
				</div>

				<!-- Projects grid -->
				<div id="panel-projects">
					<div class="grid">
						{projects.map((project) => (
							<a class="card" href={`/projects/${project.slug}/`}>
								<div class="card-thumb">
									{project.image ? (
										<img src={project.image} alt={project.name} />
									) : (
										<div class="card-thumb-default">
											<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
												<path d="M17 7.82959L18.6965 9.35641C20.239 10.7447 21.0103 11.4389 21.0103 12.3052C21.0103 13.1716 20.239 13.8658 18.6965 15.254L17 16.7808"/>
												<path d="M13.9868 5L12.9934 8.17241L11.5 12.3052L10.0066 16.438L9.01318 19.6104"/>
												<path d="M7 7.82959L5.30351 9.35641C3.76105 10.7447 2.98982 11.4389 2.98982 12.3052C2.98982 13.1716 3.76105 13.8658 5.30351 15.254L7 16.7808"/>
											</svg>
										</div>
									)}
								</div>
								<div class="card-body">
									<div class="card-top">
										<span class="card-name">{project.name}</span>
										<span class="card-year">{project.year}</span>
									</div>
									<p class="card-desc">{project.description}</p>
									<div class="card-footer">
										<div class="tags">
											{project.stack.slice(0, 3).map((tag) => (
												<span class="tag">{tag}</span>
											))}
										</div>
										<span class={`status-badge status-${project.status}`}>
											{project.status}
										</span>
									</div>
								</div>
							</a>
						))}
					</div>
				</div>

				<!-- Case studies list -->
				<div id="panel-case-studies" style="display:none">
					{caseStudies.length === 0 ? (
						<p class="cs-empty">no case studies yet — check back soon.</p>
					) : (
						<div class="cs-list">
							{caseStudies.map((cs) => {
								const filled = ANGLES.filter(a => cs[a.key]);
								return (
									<a class="cs-card" href={`/case-studies/${cs.slug}/`}>
										<div class="cs-card-top">
											<span class="cs-title">{cs.title}</span>
											<span class="cs-year">{cs.year}</span>
										</div>
										<p class="cs-summary">{cs.summary}</p>
										<div class="cs-footer">
											<div class="cs-angles">
												{filled.map(a => (
													<span class="cs-angle">{a.label}</span>
												))}
											</div>
											<span class="cs-read">Read →</span>
										</div>
									</a>
								);
							})}
						</div>
					)}
				</div>

			</div>
		</main>
		<Footer />

		<script>
			// Revisiting /projects via a View Transitions navigation doesn't
			// re-execute this module (cached per URL) — astro:page-load re-runs it
			// so the tabs wire up against the freshly-swapped-in elements each time.
			document.addEventListener('astro:page-load', () => {
				const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
				const panels: Record<string, HTMLElement | null> = {
					'projects':      document.getElementById('panel-projects'),
					'case-studies':  document.getElementById('panel-case-studies'),
				};

				function activate(tab: string) {
					tabs.forEach(t => t.classList.toggle('active', t.dataset.tab === tab));
					Object.entries(panels).forEach(([key, el]) => {
						if (el) el.style.display = key === tab ? '' : 'none';
					});
					history.replaceState(null, '', tab === 'case-studies' ? '#case-studies' : '#projects');
				}

				tabs.forEach(t => t.addEventListener('click', () => activate(t.dataset.tab!)));
				if (location.hash === '#case-studies') activate('case-studies');
			});
		</script>
	</body>
</html>
