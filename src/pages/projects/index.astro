---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { getProjects } from '../../lib/contentful';
import { SITE_TITLE } from '../../consts';

const projects = await getProjects();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Projects — ${SITE_TITLE}`}
			description="Things I've built — AI systems, tools, and experiments."
		/>
		<style>
			.page {
				width: 960px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 3rem 1rem 5rem;
			}

			.page-heading {
				font-size: 2rem;
				margin-bottom: 0.375rem;
			}

			.page-sub {
				color: var(--text-muted);
				font-size: 1rem;
				margin-bottom: 3rem;
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.25rem;
			}

			.card {
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 8px;
				overflow: hidden;
				text-decoration: none;
				display: flex;
				flex-direction: column;
				transition: border-color 0.15s, transform 0.15s;
			}

			.card:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
			}

			.card-thumb {
				width: 100%;
				aspect-ratio: 16 / 9;
				background: var(--surface-2);
				overflow: hidden;
				display: flex;
				align-items: center;
				justify-content: center;
				border-bottom: 1px solid var(--border);
			}

			.card-thumb img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.card-thumb-default {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.5rem;
				color: var(--text-muted);
				opacity: 0.3;
			}

			.card-thumb-default svg {
				width: 32px;
				height: 32px;
			}

			.card-body {
				padding: 1.125rem 1.25rem 1.25rem;
				display: flex;
				flex-direction: column;
				flex: 1;
			}

			.card-top {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 0.5rem;
				margin-bottom: 0.5rem;
			}

			.card-name {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 1rem;
				font-weight: 500;
				color: var(--text);
				line-height: 1.3;
			}

			.card-year {
				font-family: 'JetBrains Mono', monospace;
				font-size: 12px;
				color: var(--text-muted);
				white-space: nowrap;
				flex-shrink: 0;
				margin-top: 2px;
			}

			.card-desc {
				font-size: 0.9rem;
				color: var(--text-muted);
				line-height: 1.55;
				margin: 0 0 1rem 0;
				flex: 1;
			}

			.card-footer {
				display: flex;
				flex-wrap: wrap;
				gap: 0.375rem;
				align-items: center;
				justify-content: space-between;
			}

			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.375rem;
			}

			.tag {
				font-family: 'JetBrains Mono', monospace;
				font-size: 11px;
				color: var(--text-muted);
				background: var(--surface-2);
				border: 1px solid var(--border);
				border-radius: 4px;
				padding: 1px 7px;
			}

			.status-badge {
				font-family: 'JetBrains Mono', monospace;
				font-size: 11px;
				padding: 1px 8px;
				border-radius: 4px;
				border: 1px solid var(--border);
				flex-shrink: 0;
			}

			.status-active {
				color: #4ade80;
				border-color: #4ade8040;
				background: #4ade8010;
			}

			.status-completed {
				color: var(--text-muted);
			}

			.status-archived {
				color: var(--text-muted);
				opacity: 0.6;
			}

			@media (max-width: 640px) {
				.grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main style="padding: 0; max-width: 100%; width: 100%;">
			<div class="page">
				<h1 class="page-heading">Projects</h1>
				<p class="page-sub">Things I've built — AI systems, tools, and experiments.</p>

				<div class="grid">
					{projects.map((project) => (
						<a class="card" href={`/projects/${project.slug}/`}>
							<div class="card-thumb">
								{project.image ? (
									<img src={project.image} alt={project.name} />
								) : (
									<div class="card-thumb-default">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
											<path d="M17 7.82959L18.6965 9.35641C20.239 10.7447 21.0103 11.4389 21.0103 12.3052C21.0103 13.1716 20.239 13.8658 18.6965 15.254L17 16.7808"/>
											<path d="M13.9868 5L12.9934 8.17241L11.5 12.3052L10.0066 16.438L9.01318 19.6104"/>
											<path d="M7 7.82959L5.30351 9.35641C3.76105 10.7447 2.98982 11.4389 2.98982 12.3052C2.98982 13.1716 3.76105 13.8658 5.30351 15.254L7 16.7808"/>
										</svg>
									</div>
								)}
							</div>
							<div class="card-body">
								<div class="card-top">
									<span class="card-name">{project.name}</span>
									<span class="card-year">{project.year}</span>
								</div>
								<p class="card-desc">{project.description}</p>
								<div class="card-footer">
									<div class="tags">
										{project.stack.slice(0, 3).map((tag) => (
											<span class="tag">{tag}</span>
										))}
									</div>
									<span class={`status-badge status-${project.status}`}>
										{project.status}
									</span>
								</div>
							</div>
						</a>
					))}
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
