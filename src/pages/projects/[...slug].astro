---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { getProjects, getProject } from '../../lib/contentful';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const projects = await getProjects();
	return projects.map((p) => ({
		params: { slug: p.slug },
		props: { project: p },
	}));
}

const { project: stub } = Astro.props;
const project = await getProject(stub.slug);
if (!project) return Astro.redirect('/projects');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${project.name} — ${SITE_TITLE}`}
			description={project.description}
		/>
		<style>
			.prose {
				width: 720px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 3rem 1rem 5rem;
			}

			.back {
				font-family: 'JetBrains Mono', monospace;
				font-size: 13px;
				color: var(--text-muted);
				text-decoration: none;
				display: inline-flex;
				align-items: center;
				gap: 0.375rem;
				margin-bottom: 2rem;
				transition: color 0.15s;
			}

			.back:hover { color: var(--accent); }

			.hero-image {
				width: 100%;
				max-height: 360px;
				border-radius: 8px;
				overflow: hidden;
				margin-bottom: 2rem;
				background: var(--surface-2);
				border: 1px solid var(--border);
			}

			.hero-image img {
				width: 100%;
				height: 100%;
				max-height: 360px;
				object-fit: cover;
				object-position: top;
			}

			.screenshots {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
				gap: 1rem;
				margin-top: 2rem;
			}

			.screenshot {
				border-radius: 8px;
				overflow: hidden;
				border: 1px solid var(--border);
				background: var(--surface-2);
				aspect-ratio: 9 / 16;
			}

			.screenshot img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: top;
				display: block;
			}

			.project-title {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 2.25rem;
				font-weight: 700;
				color: var(--text);
				line-height: 1.15;
				margin: 0 0 1rem 0;
			}

			.meta-row {
				display: flex;
				align-items: center;
				gap: 1rem;
				flex-wrap: wrap;
				font-family: 'JetBrains Mono', monospace;
				font-size: 13px;
				color: var(--text-muted);
				margin-bottom: 1rem;
			}

			.status-badge {
				padding: 1px 8px;
				border-radius: 4px;
				border: 1px solid var(--border);
				font-size: 11px;
			}

			.status-active   { color: #4ade80; border-color: #4ade8040; background: #4ade8010; }
			.status-completed { color: var(--text-muted); }
			.status-archived  { color: var(--text-muted); opacity: 0.6; }

			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.375rem;
				margin-bottom: 1rem;
			}

			.tag {
				font-family: 'JetBrains Mono', monospace;
				font-size: 11px;
				color: var(--text-muted);
				background: var(--surface-2);
				border: 1px solid var(--border);
				border-radius: 4px;
				padding: 1px 7px;
			}

			.links {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				margin-bottom: 2rem;
			}

			.link-btn {
				font-family: 'JetBrains Mono', monospace;
				font-size: 13px;
				color: var(--accent);
				text-decoration: none;
				border: 1px solid var(--accent);
				border-radius: 4px;
				padding: 4px 12px;
				transition: background 0.15s, color 0.15s;
			}

			.link-btn:hover { background: var(--accent); color: #fff; }

			.divider {
				border: none;
				border-top: 1px solid var(--border);
				margin: 0 0 2rem;
			}

			.body :global(h2) {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 1.25rem;
				font-weight: 600;
				color: var(--text);
				margin: 2rem 0 0.75rem;
			}

			.body :global(p) {
				font-size: 0.9375rem;
				color: var(--text-muted);
				line-height: 1.75;
				margin: 0 0 1rem;
			}

			.body :global(ul) {
				padding-left: 1.25rem;
				color: var(--text-muted);
				line-height: 1.75;
				margin: 0 0 1rem;
			}

			.body :global(li) { margin-bottom: 0.4rem; }
			.body :global(strong) { color: var(--text); font-weight: 500; }
			.body :global(a) { color: var(--accent); }
		</style>
	</head>
	<body>
		<Header />
		<main style="padding: 0; max-width: 100%; width: 100%;">
			<div class="prose">
				<a class="back" href="/projects">← All projects</a>

				{project.image && (
					<div class="hero-image">
						<img src={project.image} alt={project.name} />
					</div>
				)}

				<h1 class="project-title">{project.name}</h1>

				<div class="meta-row">
					<span>{project.year}</span>
					<span class={`status-badge status-${project.status}`}>
						{project.status}
					</span>
				</div>

				{project.stack.length > 0 && (
					<div class="tags">
						{project.stack.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				)}

				{(project.github || project.demo) && (
					<div class="links">
						{project.github && (
							<a class="link-btn" href={project.github} target="_blank" rel="noopener noreferrer">
								GitHub →
							</a>
						)}
						{project.demo && (
							<a class="link-btn" href={project.demo} target="_blank" rel="noopener noreferrer">
								Live demo →
							</a>
						)}
					</div>
				)}

				<hr class="divider" />

				{project.bodyHtml && <div class="body" set:html={project.bodyHtml} />}

				{project.screenshots && project.screenshots.length > 0 && (
					<div class="screenshots">
						{project.screenshots.map((src) => (
							<div class="screenshot">
								<img src={src} alt={`${project.name} screenshot`} loading="lazy" />
							</div>
						))}
					</div>
				)}
			</div>
		</main>
		<Footer />
	</body>
</html>
