---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ShareModal from '../../components/ShareModal.astro';
import { getNote, getNotes } from '../../lib/contentful';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
  const notes = await getNotes();
  return notes.map((n) => ({ params: { slug: n.slug } }));
}

const { slug } = Astro.params;
const note = await getNote(slug!);
if (!note) return Astro.redirect('/blog#notes');

const wordCount = note.bodyHtml.replace(/<[^>]+>/g, ' ').split(/\s+/).filter(Boolean).length;
const readingTime = Math.ceil(wordCount / 200) || 1;

const formattedDate = new Date(note.pubDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<html lang="en">
  <head>
    <BaseHead title={`${note.title} — ${SITE_TITLE}`} description={note.description} />
    <style>
      .note-wrap {
        width: 720px;
        max-width: calc(100% - 2rem);
        margin: 0 auto;
        padding: 3rem 1rem 5rem;
      }

      .note-header {
        margin-bottom: 2rem;
      }

      .note-category {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent);
        background: rgba(232,96,44,0.08);
        border: 1px solid rgba(232,96,44,0.2);
        border-radius: 4px;
        padding: 2px 8px;
        display: inline-block;
        margin-bottom: 1rem;
      }

      .note-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2.25rem;
        font-weight: 700;
        color: var(--text);
        line-height: 1.15;
        margin: 0 0 1rem 0;
      }

      .note-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        color: var(--text-muted);
        flex-wrap: wrap;
      }

      .note-meta span::before {
        content: '·';
        margin-right: 1rem;
      }

      .note-meta span:first-child::before { content: none; }

      .note-source {
        display: block;
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 0.5rem;
      }

      .note-source a {
        color: var(--accent);
      }

      .divider {
        border: none;
        border-top: 1px solid var(--border);
        margin: 1.5rem 0 2rem;
      }

      .note-body {
        font-size: 1rem;
        color: var(--text-muted);
        line-height: 1.8;
      }

      .note-body h2 {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.375rem;
        font-weight: 600;
        color: var(--text);
        margin: 2rem 0 0.75rem;
      }

      .note-body h3 {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.125rem;
        font-weight: 500;
        color: var(--text);
        margin: 1.5rem 0 0.5rem;
      }

      .note-body p { margin-bottom: 1.25rem; }

      .note-body strong { color: var(--text); font-weight: 600; }

      .note-body code {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.875em;
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 1px 6px;
        color: var(--text);
      }

      .note-body pre {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 1.25rem 1.5rem;
        overflow-x: auto;
        margin: 1.5rem 0;
      }

      .note-body pre code {
        all: unset;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.875rem;
      }

      .note-body ul, .note-body ol {
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
      }

      .note-body li { margin-bottom: 0.375rem; }

      .note-body blockquote {
        border-left: 2px solid var(--accent);
        padding-left: 1.25rem;
        margin: 1.5rem 0;
        color: var(--text-muted);
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: var(--text-muted);
        text-decoration: none;
        margin-top: 3rem;
        transition: color 0.15s;
      }

      .back-link:hover { color: var(--accent); }

      #read-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 2px;
        background: var(--accent);
        z-index: 9999;
        width: 0%;
        transition: width 0.08s linear;
      }

      @media (max-width: 640px) {
        .note-title { font-size: 1.75rem; }
      }
    </style>
  </head>
  <body>
    <div id="read-progress" aria-hidden="true"></div>
    <Header />
    <main style="padding: 0; max-width: 100%; width: 100%;">
      <article>
        <div class="note-wrap">
          <div class="note-header">
            <span class="note-category">{note.category}</span>
            <h1 class="note-title">{note.title}</h1>
            <div class="note-meta">
              <span>{formattedDate}</span>
              <span>{readingTime} min read</span>
              <span class="share-slot"><ShareModal title={note.title} label="note" /></span>
            </div>
            {note.source && (
              <span class="note-source">source: <a href={note.source} target="_blank" rel="noopener noreferrer">{note.source}</a></span>
            )}
          </div>
          <hr class="divider" />
          <div class="note-body" set:html={note.bodyHtml} />
          <a class="back-link" href="/blog#notes">← back to notes</a>
        </div>
      </article>
    </main>
    <Footer />
    <script>
      const bar = document.getElementById('read-progress') as HTMLDivElement;
      function updateProgress() {
        const article = document.querySelector('article');
        if (!article || !bar) return;
        const { top, height } = article.getBoundingClientRect();
        const scrolled = Math.max(0, -top);
        const total = height - window.innerHeight;
        bar.style.width = total > 0 ? Math.min(100, (scrolled / total) * 100) + '%' : '0%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    </script>
  </body>
</html>
