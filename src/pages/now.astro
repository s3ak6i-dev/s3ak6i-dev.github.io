---
import { getCollection, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const entries = await getCollection('now');
const entry = entries[0];
const { Content } = await render(entry);

const updatedStr = entry.data.updatedDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Now — ${SITE_TITLE}`}
			description="What I'm focused on right now."
		/>
		<style>
			.page {
				width: 720px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 3rem 1rem 5rem;
			}

			.page-heading {
				font-size: 2rem;
				margin-bottom: 0.375rem;
			}

			.updated {
				font-family: 'JetBrains Mono', monospace;
				font-size: 13px;
				color: var(--text-muted);
				margin-bottom: 2.5rem;
				display: block;
			}

			.divider {
				border: none;
				border-top: 1px solid var(--border);
				margin: 0 0 2rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main style="padding: 0; max-width: 100%; width: 100%;">
			<div class="page">
				<h1 class="page-heading">Now</h1>
				<span class="updated">Updated {updatedStr}</span>
				<hr class="divider" />
				<Content />
			</div>
		</main>
		<Footer />
	</body>
</html>
