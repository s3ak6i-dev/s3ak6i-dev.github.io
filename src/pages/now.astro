---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const entries = await getCollection('now');
const entry = entries[0];
const { workingOn, reading, thinkingAbout, extracurriculars, updatedDate } = entry.data;

const updatedStr = updatedDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Now — ${SITE_TITLE}`} description="What I'm focused on right now." />
		<style>
			.page {
				width: 720px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 3rem 1rem 5rem;
			}

			.page-header {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 0.5rem;
			}

			.page-heading {
				font-size: 2rem;
				margin: 0;
			}

			.updated {
				font-family: 'JetBrains Mono', monospace;
				font-size: 12px;
				color: var(--text-muted);
				white-space: nowrap;
			}

			.divider {
				border: none;
				border-top: 1px solid var(--border);
				margin: 1.5rem 0 2.5rem;
			}

			/* Section label */
			.section-label {
				font-family: 'JetBrains Mono', monospace;
				font-size: 11px;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--accent);
				margin-bottom: 0.875rem;
			}

			.section {
				margin-bottom: 2.5rem;
			}

			/* Working On — full width */
			.working-card {
				background: var(--surface);
				border: 1px solid var(--border);
				border-left: 2px solid var(--accent);
				border-radius: 6px;
				padding: 1.25rem 1.5rem;
			}

			.working-title-row {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 1rem;
				margin-bottom: 0.5rem;
			}

			.working-title {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 1rem;
				font-weight: 500;
				color: var(--text);
				margin: 0;
			}

			.working-link {
				font-family: 'JetBrains Mono', monospace;
				font-size: 12px;
				color: var(--accent);
				text-decoration: none;
				white-space: nowrap;
				flex-shrink: 0;
			}

			.working-link:hover { opacity: 0.75; }

			.working-desc {
				font-size: 0.9375rem;
				color: var(--text-muted);
				line-height: 1.6;
				margin: 0;
			}

			/* 2-column grid for Reading + Thinking */
			.two-col {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.25rem;
			}

			@media (max-width: 600px) {
				.two-col { grid-template-columns: 1fr; }
			}

			.col-section {
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 6px;
				padding: 1.25rem 1.5rem;
			}

			/* Reading items */
			.reading-item {
				padding: 0.75rem 0;
				border-top: 1px solid var(--border);
			}

			.reading-item:first-child { border-top: none; padding-top: 0; }

			.reading-type {
				font-family: 'JetBrains Mono', monospace;
				font-size: 10px;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent);
				margin-bottom: 0.25rem;
			}

			.reading-title {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 0.9375rem;
				font-weight: 500;
				color: var(--text);
				margin: 0 0 0.125rem;
			}

			.reading-author {
				font-size: 0.8125rem;
				color: var(--text-muted);
				margin: 0 0 0.375rem;
			}

			.reading-note {
				font-size: 0.875rem;
				color: var(--text-muted);
				line-height: 1.5;
				margin: 0;
				font-style: italic;
			}

			/* Thinking items */
			.thinking-item {
				padding: 0.75rem 0;
				border-top: 1px solid var(--border);
			}

			.thinking-item:first-child { border-top: none; padding-top: 0; }

			.thinking-question {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 0.9375rem;
				font-weight: 500;
				color: var(--text);
				line-height: 1.4;
				margin: 0 0 0.375rem;
			}

			.thinking-context {
				font-size: 0.875rem;
				color: var(--text-muted);
				line-height: 1.55;
				margin: 0;
			}

			/* Extracurriculars — chip cards */
			.extras-grid {
				display: flex;
				flex-wrap: wrap;
				gap: 0.875rem;
			}

			.extra-card {
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 6px;
				padding: 0.875rem 1.125rem;
				min-width: 160px;
				flex: 1;
			}

			.extra-activity {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 0.9375rem;
				font-weight: 500;
				color: var(--text);
				margin: 0 0 0.25rem;
			}

			.extra-desc {
				font-size: 0.875rem;
				color: var(--text-muted);
				line-height: 1.5;
				margin: 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main style="padding: 0; max-width: 100%; width: 100%;">
			<div class="page">
				<div class="page-header">
					<h1 class="page-heading">Now</h1>
					<span class="updated">Updated {updatedStr}</span>
				</div>
				<hr class="divider" />

				<!-- Working On -->
				{workingOn.length > 0 && (
					<div class="section">
						<p class="section-label">Working On</p>
						{workingOn.map((item) => (
							<div class="working-card">
								<div class="working-title-row">
									<h2 class="working-title">{item.title}</h2>
									{item.link && (
										<a class="working-link" href={item.link} target="_blank" rel="noopener noreferrer">
											↗ link
										</a>
									)}
								</div>
								<p class="working-desc">{item.description}</p>
							</div>
						))}
					</div>
				)}

				<!-- Reading + Thinking About -->
				{(reading.length > 0 || thinkingAbout.length > 0) && (
					<div class="section two-col">
						{reading.length > 0 && (
							<div class="col-section">
								<p class="section-label">Reading</p>
								{reading.map((item) => (
									<div class="reading-item">
										<p class="reading-type">{item.type}</p>
										<h3 class="reading-title">{item.title}</h3>
										{item.author && <p class="reading-author">— {item.author}</p>}
										{item.note && <p class="reading-note">{item.note}</p>}
									</div>
								))}
							</div>
						)}
						{thinkingAbout.length > 0 && (
							<div class="col-section">
								<p class="section-label">Thinking About</p>
								{thinkingAbout.map((item) => (
									<div class="thinking-item">
										<p class="thinking-question">{item.question}</p>
										{item.context && <p class="thinking-context">{item.context}</p>}
									</div>
								))}
							</div>
						)}
					</div>
				)}

				<!-- Extracurriculars -->
				{extracurriculars.length > 0 && (
					<div class="section">
						<p class="section-label">Extracurriculars</p>
						<div class="extras-grid">
							{extracurriculars.map((item) => (
								<div class="extra-card">
									<h3 class="extra-activity">{item.activity}</h3>
									<p class="extra-desc">{item.description}</p>
								</div>
							))}
						</div>
					</div>
				)}
			</div>
		</main>
		<Footer />
	</body>
</html>
