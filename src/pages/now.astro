---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getNow } from '../lib/contentful';
import { SITE_TITLE } from '../consts';

const now = await getNow();
if (!now) return Astro.redirect('/');

const updatedStr = new Date(now.updatedDate).toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Now — ${SITE_TITLE}`} description="What I'm focused on right now." />
		<style>
			.page {
				width: 720px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 3rem 1rem 5rem;
			}

			.page-header {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 0.5rem;
			}

			.page-heading { font-size: 2rem; margin: 0; }

			.updated {
				font-family: 'JetBrains Mono', monospace;
				font-size: 12px;
				color: var(--text-muted);
				white-space: nowrap;
			}

			.divider {
				border: none;
				border-top: 1px solid var(--border);
				margin: 1.5rem 0 2.5rem;
			}

			/* Prose styles for Contentful rich text */
			.prose :global(h2) {
				font-family: 'JetBrains Mono', monospace;
				font-size: 11px;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--accent);
				margin: 2.5rem 0 0.875rem;
			}
			.prose :global(h2:first-child) { margin-top: 0; }
			.prose :global(p) {
				font-size: 1rem;
				color: var(--text-muted);
				line-height: 1.75;
				margin: 0 0 1rem;
			}
			.prose :global(ul) {
				padding-left: 1.25rem;
				margin: 0 0 1rem;
				color: var(--text-muted);
				line-height: 1.75;
			}
			.prose :global(li) { margin-bottom: 0.4rem; }
			.prose :global(a) { color: var(--accent); text-decoration: none; }
			.prose :global(a:hover) { color: var(--accent-dim); }
			.prose :global(strong) { color: var(--text); font-weight: 500; }
			.prose :global(hr) {
				border: none;
				border-top: 1px solid var(--border);
				margin: 2rem 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main style="padding: 0; max-width: 100%; width: 100%;">
			<div class="page">
				<div class="page-header">
					<h1 class="page-heading">Now</h1>
					<span class="updated">Updated {updatedStr}</span>
				</div>
				<hr class="divider" />
				<div class="prose" set:html={now.bodyHtml} />
			</div>
		</main>
		<Footer />
	</body>
</html>
