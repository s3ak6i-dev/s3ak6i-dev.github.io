---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import GitHubActivity from '../components/GitHubActivity.astro';
import { getNow } from '../lib/contentful';
import { SITE_TITLE } from '../consts';

const now = await getNow();
if (!now) return Astro.redirect('/');

const updatedStr = new Date(now.updatedDate).toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

// Split rich text into intro + named sections by <h2>
const rawSections = now.bodyHtml.split(/<h2[^>]*>/);
const intro = rawSections[0].trim();
const sections: { title: string; content: string }[] = [];
for (let i = 1; i < rawSections.length; i++) {
	const closeIdx = rawSections[i].indexOf('</h2>');
	const title   = rawSections[i].slice(0, closeIdx);
	const content = rawSections[i].slice(closeIdx + 5).trim();
	sections.push({ title, content });
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Now â€” ${SITE_TITLE}`} description="What I'm focused on right now." />
		<style>
			.page {
				width: 960px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 3rem 1rem 5rem;
			}

			.updated {
				font-family: 'JetBrains Mono', monospace;
				font-size: 12px;
				color: var(--text-muted);
				margin-top: 0.5rem;
				display: block;
			}

			.divider {
				border: none;
				border-top: 1px solid var(--border);
				margin: 1.5rem 0 2.5rem;
			}

			.intro {
				font-size: 1rem;
				color: var(--text-muted);
				line-height: 1.75;
				margin-bottom: 2.5rem;
				max-width: 560px;
			}

			.cards {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
				align-items: start;
			}

			@media (max-width: 768px) {
				.cards { grid-template-columns: 1fr; }
			}

			.card {
				border: 1px solid var(--border);
				border-top: 2px solid var(--accent);
				border-radius: 8px;
				padding: 1.5rem 1.5rem 1.75rem;
				background: #141414;
				transition: border-color 0.2s, box-shadow 0.2s;
			}

			.card:hover {
				border-color: rgba(232, 96, 44, 0.5);
				border-top-color: var(--accent);
				box-shadow: 0 4px 24px rgba(232, 96, 44, 0.06);
			}

			.card-label {
				font-family: 'JetBrains Mono', monospace;
				font-size: 10px;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--accent);
				margin: 0 0 1.25rem;
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}

			.card :global(p) {
				font-size: 0.9375rem;
				color: var(--text-muted);
				line-height: 1.75;
				margin: 0;
			}

			.card :global(ul) {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.card :global(li) {
				font-size: 0.9rem;
				color: var(--text-muted);
				line-height: 1.5;
				padding: 0.6rem 0;
				border-bottom: 1px solid rgba(255,255,255,0.05);
				display: flex;
				align-items: baseline;
				gap: 0.5rem;
			}

			.card :global(li::before) {
				content: 'â€”';
				color: var(--accent);
				flex-shrink: 0;
				font-size: 0.75rem;
			}

			.card :global(li:last-child) { border-bottom: none; }
			.card :global(strong) { color: var(--text); font-weight: 500; }
			.card :global(a) { color: var(--accent); text-decoration: none; }
			.card :global(a:hover) { opacity: 0.8; }

		</style>
	</head>
	<body>
		<Header />
		<PageHero
			title="Now"
			subtitle="What I'm focused on right now."
			gifSrc="https://media1.tenor.com/m/NvVxnB_7ZnIAAAAd/tyler-durden.gif"
			gifAlt="Iron Man"
		>
			<span class="updated">Updated {updatedStr}</span>
		</PageHero>
		<main style="padding: 0; max-width: 100%; width: 100%;">
			<div class="page">
				{intro && <div class="intro" set:html={intro} />}

				<div class="cards">
					{sections.map(({ title, content }) => (
						<div class="card">
							<p class="card-label">{title}</p>
							<div set:html={content} />
						</div>
					))}
				</div>
				<GitHubActivity />
			</div>
		</main>
		<Footer />
	</body>
</html>
