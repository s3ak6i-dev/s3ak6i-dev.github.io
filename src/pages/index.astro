---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Kiran from '../components/Kiran.astro';
import { GITHUB_URL, LINKEDIN_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.home {
				width: 720px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 4rem 1rem 5rem;
			}

			/* Hero */
			.hero {
				margin-bottom: 5rem;
				display: flex;
				align-items: center;
				gap: 3rem;
			}

			.hero-text {
				flex: 1;
				min-width: 0;
			}

			.hero-greeting {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 3.5rem;
				font-weight: 700;
				color: var(--text);
				line-height: 1.1;
				margin: 0 0 1rem 0;
			}

			.hero-sub {
				font-size: 1.125rem;
				color: var(--text-muted);
				margin: 0 0 1.75rem 0;
				line-height: 1.6;
			}

			.hero-ctas {
				display: flex;
				gap: 1.75rem;
				flex-wrap: wrap;
			}

			.hero-ctas a {
				font-size: 1rem;
				font-weight: 500;
				color: var(--accent);
				text-decoration: none;
			}

			.hero-ctas a:hover {
				color: var(--accent-dim);
			}

			@media (max-width: 720px) {
				.hero {
					flex-direction: column-reverse;
					gap: 2rem;
				}
			}

			/* Sections */
			.section {
				margin-bottom: 4rem;
			}

			.section-heading {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 0.8125rem;
				font-weight: 500;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--text-muted);
				margin: 0 0 1.5rem 0;
			}

			/* Recent writing */
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0 0 1.25rem 0;
			}

			.post-item {
				padding: 0.875rem 0;
				border-top: 1px solid var(--border);
			}

			.post-item:last-child {
				border-bottom: 1px solid var(--border);
			}

			.post-inner {
				display: flex;
				gap: 1rem;
				align-items: flex-start;
			}

			.post-thumb {
				width: 72px;
				height: 52px;
				flex-shrink: 0;
				border-radius: 4px;
				overflow: hidden;
				background: var(--surface-2);
				border: 1px solid var(--border);
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.post-thumb img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.post-thumb-default {
				width: 20px;
				height: 20px;
				opacity: 0.25;
			}

			.post-content {
				flex: 1;
				min-width: 0;
			}

			.post-row {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
				margin-bottom: 0.25rem;
			}

			.post-link {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 1rem;
				font-weight: 500;
				color: var(--text);
				text-decoration: none;
			}

			.post-link:hover {
				color: var(--accent);
			}

			.post-date {
				font-family: 'JetBrains Mono', monospace;
				font-size: 13px;
				color: var(--text-muted);
				white-space: nowrap;
				flex-shrink: 0;
			}

			.post-desc {
				font-size: 0.9375rem;
				color: var(--text-muted);
				margin: 0;
				line-height: 1.5;
			}

			.view-all {
				font-size: 0.9375rem;
				color: var(--accent);
			}

			.view-all:hover {
				color: var(--accent-dim);
			}

			/* About */
			.about-text {
				font-size: 1rem;
				color: var(--text-muted);
				line-height: 1.75;
				margin: 0;
			}

			.about-text a {
				color: var(--accent);
			}

			.about-text a:hover {
				color: var(--accent-dim);
			}

			@media (max-width: 640px) {
				.hero-greeting {
					font-size: 2.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main style="padding: 0; max-width: 100%; width: 100%;">
			<div class="home">
				<!-- Hero -->
				<section class="hero">
					<div class="hero-text">
						<h1 class="hero-greeting">Hey, I'm Surya.</h1>
						<p class="hero-sub">AI Engineer. I think about how constrained systems coordinate under uncertainty.</p>
						<div class="hero-ctas">
							<a href="/blog">Read the blog →</a>
							<a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">View GitHub →</a>
						</div>
					</div>
					<Kiran />
				</section>

				<!-- Recent Writing -->
				<section class="section">
					<h2 class="section-heading">Recent Writing</h2>
					<ul class="post-list">
						{
							posts.map((post) => {
								const dateStr = post.data.pubDate.toLocaleDateString('en-US', {
									year: 'numeric',
									month: 'short',
									day: 'numeric',
								});
								return (
									<li class="post-item">
										<div class="post-inner">
											<a href={`/blog/${post.id}/`} class="post-thumb" tabindex="-1" aria-hidden="true">
												{post.data.heroImage ? (
													<img src={post.data.heroImage} alt="" />
												) : (
													<svg class="post-thumb-default" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
														<rect x="3" y="3" width="18" height="18" rx="2"/>
														<path d="M3 9h18M9 21V9"/>
													</svg>
												)}
											</a>
											<div class="post-content">
												<div class="post-row">
													<a class="post-link" href={`/blog/${post.id}/`}>
														{post.data.title}
													</a>
													<span class="post-date">{dateStr}</span>
												</div>
												{post.data.description && (
													<p class="post-desc">{post.data.description}</p>
												)}
											</div>
										</div>
									</li>
								);
							})
						}
					</ul>
					<a class="view-all" href="/blog">View all posts →</a>
				</section>

				<!-- About -->
				<section class="section">
					<h2 class="section-heading">About</h2>
					<p class="about-text">
						I'm a final-year AI &amp; Computer Science student at Amrita Vishwa Vidyapeetham, Bengaluru.
						I build systems at the intersection of machine learning and product. Two IEEE publications,
						a filed patent, and five shipped projects. Looking for AI Engineer and Full-Stack AI roles
						at Bangalore startups. Find me on{' '}
						<a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a> or{' '}
						<a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer">LinkedIn</a>.
					</p>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>
