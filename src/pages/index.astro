---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import DotGrid from '../components/DotGrid.astro';
import { getBlogPosts } from '../lib/contentful';
import { GITHUB_URL, LINKEDIN_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getBlogPosts()).slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.home {
				width: 720px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 0 1rem 5rem;
			}


			/* Hero */
			.hero {
				position: relative;
				width: 100%;
				height: 480px;
				overflow: hidden;
				margin-bottom: 4rem;
				display: flex;
				align-items: center;
			}

			.hero-inner {
				position: relative;
				z-index: 1;
				width: 100%;
				max-width: 900px;
				margin: 0 auto;
				padding: 0 max(1.5rem, 3vw);
				display: flex;
				align-items: center;
				justify-content: flex-end;
				gap: 2.5rem;
			}

			.hero-content {
				flex: 0 0 auto;
				max-width: 460px;
			}

			/* soft bottom fade */
			.hero::after {
				content: '';
				position: absolute;
				inset: auto 0 0 0;
				height: 80px;
				background: linear-gradient(to bottom, transparent, var(--body-bg, #0d0d0d));
				z-index: 2;
				pointer-events: none;
			}

			.hero-gif {
				width: 340px;
				flex-shrink: 0;
				border-radius: 8px;
				overflow: hidden;
			}

			.hero-gif img {
				display: block;
				width: 100%;
				height: auto;
			}

			@media (max-width: 768px) {
				.hero { height: auto; padding: 3rem 0 4rem; overflow: visible; }
				.hero-inner { flex-direction: column; align-items: flex-start; gap: 2rem; padding: 0 1.25rem; }
				.hero-gif { width: 100%; max-width: 340px; }
				.hero-content { max-width: 100%; }
			}

			@media (max-width: 480px) {
				.hero-greeting { font-size: 2.75rem; }
				.hero-sub { font-size: 1rem; }
			}

			.hero-greeting {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 3.5rem;
				font-weight: 700;
				color: var(--text);
				line-height: 1.1;
				margin: 0 0 1rem 0;
			}

			.hero-sub {
				font-size: 1.125rem;
				color: var(--text-muted);
				margin: 0 0 1.75rem 0;
				line-height: 1.6;
				max-width: 420px;
			}

			.hero-ctas {
				display: flex;
				gap: 1.75rem;
				flex-wrap: wrap;
			}

			.hero-ctas a {
				font-size: 1rem;
				font-weight: 500;
				color: var(--accent);
				text-decoration: none;
			}

			.hero-ctas a:hover {
				color: var(--accent-dim);
			}

			@media (max-width: 720px) {
				.hero-greeting { font-size: 2.5rem; }
			}

			/* Sections */
			.section {
				margin-bottom: 4rem;
			}

			.section-heading {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 0.8125rem;
				font-weight: 500;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--text-muted);
				margin: 0 0 1.5rem 0;
			}

			/* Recent writing */
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0 0 1.25rem 0;
			}

			.post-item {
				padding: 0.875rem 0;
				border-top: 1px solid var(--border);
			}

			.post-item:last-child {
				border-bottom: 1px solid var(--border);
			}

			.post-inner {
				display: flex;
				gap: 1rem;
				align-items: flex-start;
			}

			.post-thumb {
				width: 72px;
				height: 52px;
				flex-shrink: 0;
				border-radius: 4px;
				overflow: hidden;
				background: var(--surface-2);
				border: 1px solid var(--border);
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.post-thumb img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.post-thumb-default {
				width: 20px;
				height: 20px;
				opacity: 0.25;
			}

			.post-content {
				flex: 1;
				min-width: 0;
			}

			.post-row {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				flex-wrap: wrap;
				gap: 0.25rem 1rem;
				margin-bottom: 0.25rem;
			}

			.post-link {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 1rem;
				font-weight: 500;
				color: var(--text);
				text-decoration: none;
			}

			.post-link:hover {
				color: var(--accent);
			}

			.post-date {
				font-family: 'JetBrains Mono', monospace;
				font-size: 13px;
				color: var(--text-muted);
				white-space: nowrap;
				flex-shrink: 0;
			}

			.post-desc {
				font-size: 0.9375rem;
				color: var(--text-muted);
				margin: 0;
				line-height: 1.5;
			}

			.view-all {
				font-size: 0.9375rem;
				color: var(--accent);
			}

			.view-all:hover {
				color: var(--accent-dim);
			}

			/* About */
			.about-text {
				font-size: 1rem;
				color: var(--text-muted);
				line-height: 1.75;
				margin: 0;
			}

			.about-text a {
				color: var(--accent);
			}

			.about-text a:hover {
				color: var(--accent-dim);
			}

			.tw-cursor {
				color: var(--accent);
				animation: tw-blink 0.9s step-end infinite;
				font-weight: 300;
			}

			@keyframes tw-blink {
				0%, 100% { opacity: 1; }
				50%       { opacity: 0; }
			}

		</style>
	</head>
	<body>
		<Header />
		<main style="padding: 0; max-width: 100%; width: 100%;">
			<!-- Hero -->
			<section class="hero">
				<DotGrid />
				<div class="hero-inner">
					<div class="hero-content">
						<h1 class="hero-greeting">Hey, I'm Surya.</h1>
						<p class="hero-sub"><span id="tw"></span><span class="tw-cursor">▋</span></p>
						<div class="hero-ctas">
							<a href="/blog">Read the blog →</a>
							<a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">View GitHub →</a>
						</div>
					</div>

					<div class="hero-gif">
						<img src="https://media.tenor.com/sPfOLivPN-wAAAAd/spongebob-squarepants.gif" alt="SpongeBob saying hi" />
					</div>
				</div>
			</section>

			<div class="home">
				<!-- Recent Writing -->
				<section class="section">
					<h2 class="section-heading">Recent Writing</h2>
					<ul class="post-list">
						{
							posts.map((post) => {
								const dateStr = new Date(post.pubDate).toLocaleDateString('en-US', {
									year: 'numeric',
									month: 'short',
									day: 'numeric',
								});
								return (
									<li class="post-item">
										<div class="post-inner">
											<a href={`/blog/${post.slug}/`} class="post-thumb" tabindex="-1" aria-hidden="true">
												{post.heroImage ? (
													<img src={post.heroImage} alt="" />
												) : (
													<svg class="post-thumb-default" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
														<rect x="3" y="3" width="18" height="18" rx="2"/>
														<path d="M3 9h18M9 21V9"/>
													</svg>
												)}
											</a>
											<div class="post-content">
												<div class="post-row">
													<a class="post-link" href={`/blog/${post.slug}/`}>
														{post.title}
													</a>
													<span class="post-date">{dateStr}</span>
												</div>
												{post.description && (
													<p class="post-desc">{post.description}</p>
												)}
											</div>
										</div>
									</li>
								);
							})
						}
					</ul>
					<a class="view-all" href="/blog">View all posts →</a>
				</section>

				<!-- About -->
				<section class="section">
					<h2 class="section-heading">About</h2>
					<p class="about-text">
						I'm a final-year AI &amp; Computer Science student at Amrita Vishwa Vidyapeetham, Bengaluru.
						I build systems at the intersection of machine learning and product. Two IEEE publications,
						a filed patent, and five shipped projects. Find me on{' '}
						<a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a> or{' '}
						<a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer">LinkedIn</a>.
					</p>
				</section>
			</div>
		</main>
		<Footer />
		<script>
			(() => {
				const phrases = [
					'AI Engineer. Building at the intersection of ML and systems.',
					'ML Researcher. 2 IEEE publications, 1 filed patent.',
					'Builder. 6 projects shipped.',
				];

				const el    = document.getElementById('tw');
				if (!el) return;

				let pi    = 0;   // phrase index
				let ci    = 0;   // char index
				let del   = false;

				const TYPE_MS   = 42;
				const DEL_MS    = 18;
				const PAUSE_END = 2200;
				const PAUSE_NEW = 350;

				function tick() {
					const phrase = phrases[pi];

					if (!del) {
						el.textContent = phrase.slice(0, ++ci);
						if (ci === phrase.length) {
							del = true;
							setTimeout(tick, PAUSE_END);
						} else {
							setTimeout(tick, TYPE_MS);
						}
					} else {
						el.textContent = phrase.slice(0, --ci);
						if (ci === 0) {
							del = false;
							pi  = (pi + 1) % phrases.length;
							setTimeout(tick, PAUSE_NEW);
						} else {
							setTimeout(tick, DEL_MS);
						}
					}
				}

				setTimeout(tick, 400);
			})();
		</script>
	</body>
</html>
