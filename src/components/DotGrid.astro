---
---

<canvas id="dotgrid-canvas" style="position:absolute;inset:0;width:100%;height:100%;display:block;"></canvas>

<script>
const canvas = document.getElementById('dotgrid-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

let W = 0, H = 0;
const mouse = { x: -9999, y: -9999, active: false };

const SPACING       = 28;
const DOT_R         = 1.5;
const CURSOR_R      = 150;
const REPEL         = 6;
const SPRING_K      = 0.10;
const DAMPING       = 0.70;
const BASE_ALPHA    = 0.10;
const ACTIVE_ALPHA  = 0.80;

type Dot = { hx:number; hy:number; ox:number; oy:number; vx:number; vy:number; };
let dots: Dot[] = [];

function buildGrid() {
  dots = [];
  const cols = Math.ceil(W / SPACING) + 2;
  const rows = Math.ceil(H / SPACING) + 2;
  const startX = -((cols * SPACING - W) / 2);
  const startY = -((rows * SPACING - H) / 2);
  for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) {
      dots.push({ hx: startX + c*SPACING, hy: startY + r*SPACING, ox:0, oy:0, vx:0, vy:0 });
    }
  }
}

function resize() {
  const p = canvas.parentElement!;
  W = canvas.width  = p.offsetWidth;
  H = canvas.height = p.offsetHeight;
  buildGrid();
}
window.addEventListener('resize', resize);

canvas.parentElement!.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouse.x = e.clientX - r.left;
  mouse.y = e.clientY - r.top;
  mouse.active = true;
});
canvas.parentElement!.addEventListener('mouseleave', () => { mouse.active = false; });

// touch support
canvas.parentElement!.addEventListener('touchmove', e => {
  const r = canvas.getBoundingClientRect();
  mouse.x = e.touches[0].clientX - r.left;
  mouse.y = e.touches[0].clientY - r.top;
  mouse.active = true;
}, { passive: true });
canvas.parentElement!.addEventListener('touchend', () => { mouse.active = false; });

function update() {
  const mx = mouse.x, my = mouse.y;
  for (const d of dots) {
    const cx = d.hx + d.ox;
    const cy = d.hy + d.oy;
    const dx = cx - mx, dy = cy - my;
    const d2 = dx*dx + dy*dy;

    if (mouse.active && d2 < CURSOR_R * CURSOR_R && d2 > 0) {
      const dist = Math.sqrt(d2);
      const force = REPEL * Math.pow(1 - dist / CURSOR_R, 2);
      d.vx += (dx / dist) * force;
      d.vy += (dy / dist) * force;
    }

    // spring toward home
    d.vx -= d.ox * SPRING_K;
    d.vy -= d.oy * SPRING_K;
    d.vx *= DAMPING;
    d.vy *= DAMPING;
    d.ox += d.vx;
    d.oy += d.vy;
  }
}

function draw() {
  ctx.clearRect(0, 0, W, H);
  const mx = mouse.x, my = mouse.y;

  for (const d of dots) {
    const cx = d.hx + d.ox;
    const cy = d.hy + d.oy;
    const dx = cx - mx, dy = cy - my;
    const dist = Math.sqrt(dx*dx + dy*dy);

    let alpha: number;
    if (mouse.active && dist < CURSOR_R) {
      const t = 1 - dist / CURSOR_R;
      alpha = BASE_ALPHA + (ACTIVE_ALPHA - BASE_ALPHA) * t * t;
    } else {
      alpha = BASE_ALPHA;
    }

    ctx.beginPath();
    ctx.arc(cx, cy, DOT_R, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(232,96,44,${alpha})`;
    ctx.fill();
  }
}

let running = true;
function loop() {
  if (!running) return;
  update();
  draw();
  requestAnimationFrame(loop);
}

function start() {
  resize();
  if (W === 0 || H === 0) { requestAnimationFrame(start); return; }
  loop();
}

requestAnimationFrame(start);
window.addEventListener('beforeunload', () => { running = false; }, { once: true });
</script>
