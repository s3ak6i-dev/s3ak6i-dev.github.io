---
interface Props {
	title:    string;
	subtitle: string;
	gifSrc:   string;
	gifAlt?:  string;
}

const { title, subtitle, gifSrc, gifAlt = '' } = Astro.props;
---

<section class="page-hero">
	<canvas class="hero-canvas"></canvas>
	<div class="page-hero-inner">
		<div class="page-hero-text">
			<h1>{title}</h1>
			<p>{subtitle}</p>
			<slot />
		</div>
		<div class="page-hero-gif">
			<img src={gifSrc} alt={gifAlt} />
		</div>
	</div>
	<div class="hero-fade"></div>
</section>

<style>
	.page-hero {
		background: var(--surface);
		position: relative;
		overflow: hidden;
	}

	.hero-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		display: block;
		z-index: 0;
	}

	.hero-fade {
		position: absolute;
		inset: auto 0 0 0;
		height: 80px;
		background: linear-gradient(to bottom, transparent, #0d0d0d);
		pointer-events: none;
		z-index: 1;
	}

	.page-hero-inner {
		max-width: 960px;
		margin: 0 auto;
		padding: 2.75rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2.5rem;
		position: relative;
		z-index: 2;
	}

	.page-hero-text {
		flex: 1;
	}

	.page-hero-text h1 {
		font-size: 2.75rem;
		font-weight: 700;
		margin: 0 0 0.5rem;
		line-height: 1.1;
	}

	.page-hero-text p {
		font-size: 1rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.6;
	}

	.page-hero-gif {
		width: 220px;
		flex-shrink: 0;
	}

	.page-hero-gif img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 4px;
	}

	@media (max-width: 640px) {
		.page-hero-inner {
			flex-direction: column-reverse;
			gap: 1.5rem;
			padding: 2rem 1.25rem;
		}

		.page-hero-gif {
			width: 160px;
		}

		.page-hero-text h1 {
			font-size: 2.25rem;
		}
	}
</style>

<script>
// `astro:page-load` fires on the initial load AND after every View Transitions
// navigation. PageHero is reused across many pages, so without this, the
// canvas setup only ever ran for whichever page happened to load it first —
// every other page's canvas sat inert until a hard reload.
document.addEventListener('astro:page-load', () => {
  (window as any).__pageHeroCleanup?.();

  const canvas = document.querySelector('.hero-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;
  const section = canvas.parentElement!;

  let W = 0, H = 0;
  const mouse = { x: -9999, y: -9999, active: false };

  const SPACING    = 28;
  const DOT_R      = 1.5;
  const CURSOR_R   = 150;
  const REPEL      = 6;
  const SPRING_K   = 0.10;
  const DAMPING    = 0.70;
  const BASE_ALPHA = 0.10;
  const ACTIVE_ALPHA = 0.80;

  type Dot = { hx:number; hy:number; ox:number; oy:number; vx:number; vy:number };
  let dots: Dot[] = [];

  function buildGrid() {
    dots = [];
    const cols = Math.ceil(W / SPACING) + 2;
    const rows = Math.ceil(H / SPACING) + 2;
    const startX = -((cols * SPACING - W) / 2);
    const startY = -((rows * SPACING - H) / 2);
    for (let r = 0; r < rows; r++)
      for (let c = 0; c < cols; c++)
        dots.push({ hx: startX + c*SPACING, hy: startY + r*SPACING, ox:0, oy:0, vx:0, vy:0 });
  }

  function resize() {
    W = canvas.width  = section.offsetWidth;
    H = canvas.height = section.offsetHeight;
    buildGrid();
  }
  window.addEventListener('resize', resize);

  const onMouseMove = (e: MouseEvent) => {
    const r = section.getBoundingClientRect();
    mouse.x = e.clientX - r.left;
    mouse.y = e.clientY - r.top;
    mouse.active = true;
  };
  const onMouseLeave = () => { mouse.active = false; };
  const onTouchMove = (e: TouchEvent) => {
    const r = section.getBoundingClientRect();
    mouse.x = e.touches[0].clientX - r.left;
    mouse.y = e.touches[0].clientY - r.top;
    mouse.active = true;
  };
  const onTouchEnd = () => { mouse.active = false; };

  section.addEventListener('mousemove', onMouseMove);
  section.addEventListener('mouseleave', onMouseLeave);
  section.addEventListener('touchmove', onTouchMove, { passive: true });
  section.addEventListener('touchend', onTouchEnd);

  function update() {
    const mx = mouse.x, my = mouse.y;
    for (const d of dots) {
      const cx = d.hx + d.ox, cy = d.hy + d.oy;
      const dx = cx - mx, dy = cy - my;
      const d2 = dx*dx + dy*dy;
      if (mouse.active && d2 < CURSOR_R * CURSOR_R && d2 > 0) {
        const dist = Math.sqrt(d2);
        const force = REPEL * Math.pow(1 - dist / CURSOR_R, 2);
        d.vx += (dx / dist) * force;
        d.vy += (dy / dist) * force;
      }
      d.vx -= d.ox * SPRING_K;
      d.vy -= d.oy * SPRING_K;
      d.vx *= DAMPING;
      d.vy *= DAMPING;
      d.ox += d.vx;
      d.oy += d.vy;
    }
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    const mx = mouse.x, my = mouse.y;
    for (const d of dots) {
      const cx = d.hx + d.ox, cy = d.hy + d.oy;
      const dx = cx - mx, dy = cy - my;
      const dist = Math.sqrt(dx*dx + dy*dy);
      const alpha = (mouse.active && dist < CURSOR_R)
        ? BASE_ALPHA + (ACTIVE_ALPHA - BASE_ALPHA) * Math.pow(1 - dist / CURSOR_R, 2)
        : BASE_ALPHA;
      ctx.beginPath();
      ctx.arc(cx, cy, DOT_R, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(232,96,44,${alpha})`;
      ctx.fill();
    }
  }

  let running = true;
  function loop() {
    if (!running) return;
    update(); draw();
    requestAnimationFrame(loop);
  }

  function start() {
    resize();
    if (W === 0 || H === 0) { requestAnimationFrame(start); return; }
    loop();
  }
  requestAnimationFrame(start);

  (window as any).__pageHeroCleanup = () => {
    running = false;
    window.removeEventListener('resize', resize);
  };
});
</script>
