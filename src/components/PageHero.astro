---
interface Props {
	title:    string;
	subtitle: string;
	gifSrc:   string;
	gifAlt?:  string;
}

const { title, subtitle, gifSrc, gifAlt = '' } = Astro.props;
---

<section class="page-hero">
	<div class="page-hero-inner">
		<div class="page-hero-text">
			<h1>{title}</h1>
			<p>{subtitle}</p>
			<slot />
		</div>
		<div class="page-hero-gif">
			<img src={gifSrc} alt={gifAlt} />
		</div>
	</div>
</section>

<style>
	.page-hero {
		background: var(--surface);
		border-bottom: 1px solid var(--border);
	}

	.page-hero-inner {
		max-width: 960px;
		margin: 0 auto;
		padding: 2.75rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2.5rem;
	}

	.page-hero-text {
		flex: 1;
	}

	.page-hero-text h1 {
		font-size: 2.75rem;
		font-weight: 700;
		margin: 0 0 0.5rem;
		line-height: 1.1;
	}

	.page-hero-text p {
		font-size: 1rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.6;
	}

	.page-hero-gif {
		width: 220px;
		flex-shrink: 0;
		border-radius: 10px;
		overflow: hidden;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
	}

	.page-hero-gif img {
		display: block;
		width: 100%;
		height: auto;
	}

	@media (max-width: 640px) {
		.page-hero-inner {
			flex-direction: column-reverse;
			gap: 1.5rem;
			padding: 2rem 1.25rem;
		}

		.page-hero-gif {
			width: 160px;
		}

		.page-hero-text h1 {
			font-size: 2.25rem;
		}
	}
</style>
