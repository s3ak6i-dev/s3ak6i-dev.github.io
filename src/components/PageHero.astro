---
interface Props {
	title:    string;
	subtitle: string;
	gifSrc:   string;
	gifAlt?:  string;
}

const { title, subtitle, gifSrc, gifAlt = '' } = Astro.props;
---

<section class="page-hero">
	<div class="page-hero-inner">
		<div class="page-hero-text">
			<h1>{title}</h1>
			<p>{subtitle}</p>
			<slot />
		</div>
		<div class="page-hero-gif">
			<img src={gifSrc} alt={gifAlt} />
		</div>
	</div>
</section>

<style>
	.page-hero {
		background: var(--surface);
		position: relative;
		overflow: hidden;
	}

	.page-hero::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image: radial-gradient(circle, rgba(232,96,44,0.10) 1.2px, transparent 1.2px);
		background-size: 28px 28px;
		pointer-events: none;
		z-index: 0;
	}

	.page-hero::after {
		content: '';
		position: absolute;
		inset: auto 0 0 0;
		height: 80px;
		background: linear-gradient(to bottom, transparent, var(--bg));
		pointer-events: none;
		z-index: 1;
	}

	.page-hero-inner {
		max-width: 960px;
		margin: 0 auto;
		padding: 2.75rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2.5rem;
		position: relative;
		z-index: 2;
	}

	.page-hero-text {
		flex: 1;
	}

	.page-hero-text h1 {
		font-size: 2.75rem;
		font-weight: 700;
		margin: 0 0 0.5rem;
		line-height: 1.1;
	}

	.page-hero-text p {
		font-size: 1rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.6;
	}

	.page-hero-gif {
		width: 220px;
		flex-shrink: 0;
	}

	.page-hero-gif img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 4px;
	}

	@media (max-width: 640px) {
		.page-hero-inner {
			flex-direction: column-reverse;
			gap: 1.5rem;
			padding: 2rem 1.25rem;
		}

		.page-hero-gif {
			width: 160px;
		}

		.page-hero-text h1 {
			font-size: 2.25rem;
		}
	}
</style>
