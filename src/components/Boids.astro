---
---

<canvas id="boids-canvas" style="position:absolute;inset:0;width:100%;height:100%;display:block;"></canvas>

<script>
const canvas = document.getElementById('boids-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

let W = 0, H = 0;
const mouse = { x: -9999, y: -9999, active: false };

function resize() {
  const p = canvas.parentElement!;
  W = canvas.width  = p.offsetWidth;
  H = canvas.height = p.offsetHeight;
}
window.addEventListener('resize', resize);

canvas.parentElement!.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouse.x = e.clientX - r.left;
  mouse.y = e.clientY - r.top;
  mouse.active = true;
});
canvas.parentElement!.addEventListener('mouseleave', () => { mouse.active = false; });

// ── parameters ───────────────────────────────────────────────────────────────
const N             = 220;
const MAX_SPEED     = 2.4;
const MAX_FORCE     = 0.05;
const PERC_R        = 80;
const SEP_R         = 26;
const CURSOR_R      = 170;
const CURSOR_REPEL  = 60;
const W_SEP = 1.8, W_ALI = 1.0, W_COH = 1.0, W_CUR = 1.4;

// flat typed arrays — cache-friendly
const px = new Float32Array(N);
const py = new Float32Array(N);
const vx = new Float32Array(N);
const vy = new Float32Array(N);
const ax = new Float32Array(N);
const ay = new Float32Array(N);
const sz = new Float32Array(N);
const br = new Float32Array(N);

function initBoids() {
  for (let i = 0; i < N; i++) {
    px[i] = Math.random() * W;
    py[i] = Math.random() * H;
    const angle = Math.random() * Math.PI * 2;
    const spd = MAX_SPEED * (0.4 + Math.random() * 0.6);
    vx[i] = Math.cos(angle) * spd;
    vy[i] = Math.sin(angle) * spd;
    sz[i] = 1.5 + Math.random() * 1.5;
    br[i] = 0.4 + Math.random() * 0.6;
  }
}

// ── flocking ─────────────────────────────────────────────────────────────────
function steerTo(dx: number, dy: number, cvx: number, cvy: number): [number, number] {
  const m = Math.sqrt(dx * dx + dy * dy) || 1;
  let fx = (dx / m) * MAX_SPEED - cvx;
  let fy = (dy / m) * MAX_SPEED - cvy;
  const fm = Math.sqrt(fx * fx + fy * fy);
  if (fm > MAX_FORCE) { fx = (fx / fm) * MAX_FORCE; fy = (fy / fm) * MAX_FORCE; }
  return [fx, fy];
}

function capSpeed(i: number) {
  const m = Math.sqrt(vx[i] * vx[i] + vy[i] * vy[i]);
  if (m > MAX_SPEED) { vx[i] = (vx[i] / m) * MAX_SPEED; vy[i] = (vy[i] / m) * MAX_SPEED; }
}

function update() {
  for (let i = 0; i < N; i++) {
    let sepX = 0, sepY = 0, aliX = 0, aliY = 0, cohX = 0, cohY = 0;
    let sepN = 0, flockN = 0;

    for (let j = 0; j < N; j++) {
      if (i === j) continue;
      const dx = px[j] - px[i], dy = py[j] - py[i];
      const d2 = dx * dx + dy * dy;

      if (d2 < SEP_R * SEP_R && d2 > 0) {
        const d = Math.sqrt(d2);
        sepX -= dx / d;
        sepY -= dy / d;
        sepN++;
      }
      if (d2 < PERC_R * PERC_R) {
        aliX += vx[j]; aliY += vy[j];
        cohX += px[j]; cohY += py[j];
        flockN++;
      }
    }

    let fx = 0, fy = 0;

    if (sepN > 0) {
      const [sx, sy] = steerTo(sepX / sepN, sepY / sepN, vx[i], vy[i]);
      fx += sx * W_SEP; fy += sy * W_SEP;
    }
    if (flockN > 0) {
      const [alx, aly] = steerTo(aliX / flockN, aliY / flockN, vx[i], vy[i]);
      fx += alx * W_ALI; fy += aly * W_ALI;
      const [cx, cy] = steerTo(cohX / flockN - px[i], cohY / flockN - py[i], vx[i], vy[i]);
      fx += cx * W_COH; fy += cy * W_COH;
    }

    // cursor influence
    if (mouse.active) {
      const dx = mouse.x - px[i], dy = mouse.y - py[i];
      const d2 = dx * dx + dy * dy;
      if (d2 < CURSOR_R * CURSOR_R && d2 > 0) {
        const d = Math.sqrt(d2);
        if (d < CURSOR_REPEL) {
          // repel — hard push away
          const str = (1 - d / CURSOR_REPEL) * MAX_FORCE * 6;
          fx -= (dx / d) * str * W_CUR;
          fy -= (dy / d) * str * W_CUR;
        } else {
          // attract toward cursor
          const t = 1 - (d - CURSOR_REPEL) / (CURSOR_R - CURSOR_REPEL);
          const [cx, cy] = steerTo(dx, dy, vx[i], vy[i]);
          fx += cx * W_CUR * t * 2;
          fy += cy * W_CUR * t * 2;
        }
      }
    }

    ax[i] = fx; ay[i] = fy;
  }

  for (let i = 0; i < N; i++) {
    vx[i] += ax[i]; vy[i] += ay[i];
    capSpeed(i);
    px[i] = (px[i] + vx[i] + W) % W;
    py[i] = (py[i] + vy[i] + H) % H;
  }
}

// ── palette ───────────────────────────────────────────────────────────────────
// #E8602C orange, #DCA320 amber, #C84010 deep orange
const PALETTE = [[232,96,44],[220,163,32],[200,64,16]] as const;

function draw() {
  // fade trail — semi-transparent dark overlay
  ctx.fillStyle = 'rgba(13,13,13,0.16)';
  ctx.fillRect(0, 0, W, H);

  for (let i = 0; i < N; i++) {
    const speed = Math.sqrt(vx[i] * vx[i] + vy[i] * vy[i]);
    const t = speed / MAX_SPEED;
    const [r, g, b] = PALETTE[i % 3];
    const alpha = (0.25 + br[i] * 0.75) * (0.4 + 0.6 * t);
    const s = sz[i];

    ctx.save();
    ctx.translate(px[i], py[i]);
    ctx.rotate(Math.atan2(vy[i], vx[i]));
    ctx.beginPath();
    ctx.moveTo(s * 3.2, 0);
    ctx.lineTo(-s, -s * 0.85);
    ctx.lineTo(-s * 0.4, 0);
    ctx.lineTo(-s, s * 0.85);
    ctx.closePath();
    ctx.fillStyle = `rgba(${r},${g},${b},${alpha})`;
    ctx.fill();
    ctx.restore();
  }

  // subtle glow at cursor
  if (mouse.active) {
    const g = ctx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, CURSOR_REPEL * 1.4);
    g.addColorStop(0, 'rgba(232,96,44,0.12)');
    g.addColorStop(1, 'rgba(232,96,44,0)');
    ctx.fillStyle = g;
    ctx.beginPath();
    ctx.arc(mouse.x, mouse.y, CURSOR_REPEL * 1.4, 0, Math.PI * 2);
    ctx.fill();
  }
}

// ── loop ──────────────────────────────────────────────────────────────────────
let running = true;

function loop() {
  if (!running) return;
  update();
  draw();
  requestAnimationFrame(loop);
}

function start() {
  resize();
  if (W === 0 || H === 0) { requestAnimationFrame(start); return; }
  // fill background before first frame so trail fade works from the start
  ctx.fillStyle = '#0d0d0d';
  ctx.fillRect(0, 0, W, H);
  initBoids();
  loop();
}

requestAnimationFrame(start);
window.addEventListener('beforeunload', () => { running = false; }, { once: true });
</script>
