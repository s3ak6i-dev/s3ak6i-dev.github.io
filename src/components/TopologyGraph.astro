---
---

<canvas id="topology-canvas" style="position:absolute;inset:0;width:100%;height:100%;display:block;pointer-events:none;"></canvas>

<script>
const canvas = document.getElementById('topology-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

let W = 0, H = 0;
const mouse = { x: -9999, y: -9999, active: false };

// nodes live in the right portion of the hero
const ZONE_L = 0.50;
const ZONE_R = 0.96;
const ZONE_T = 0.06;
const ZONE_B = 0.94;

const N         = 14;
const REST_LEN  = 88;
const REPEL_K   = 7000;
const SPRING_K  = 0.014;
const DAMPING   = 0.85;
const MAX_SPD   = 3.5;
const BOUND_K   = 0.25;
const CURSOR_R  = 120;
const CURSOR_K  = 3500;

interface Node   { x:number; y:number; vx:number; vy:number; }
interface Edge   { a:number; b:number; }
interface Signal { a:number; b:number; t:number; spd:number; }

let nodes:   Node[]   = [];
let edges:   Edge[]   = [];
let signals: Signal[] = [];

let nextSignal = 0;
let nextKick   = 0;
let lastTime   = 0;
let running    = true;

function buildGraph() {
  nodes = [];
  const xMin = W*ZONE_L, xMax = W*ZONE_R;
  const yMin = H*ZONE_T, yMax = H*ZONE_B;
  for (let i = 0; i < N; i++) {
    nodes.push({ x: xMin + Math.random()*(xMax-xMin), y: yMin + Math.random()*(yMax-yMin), vx:0, vy:0 });
  }

  // connect each node to its 3 nearest neighbours
  edges = [];
  const seen = new Set<string>();
  for (let i = 0; i < N; i++) {
    nodes
      .map((_, j) => {
        const dx = nodes[j].x-nodes[i].x, dy = nodes[j].y-nodes[i].y;
        return { j, d: dx*dx+dy*dy };
      })
      .filter(({j}) => j !== i)
      .sort((a,b) => a.d-b.d)
      .slice(0, 3)
      .forEach(({j}) => {
        const key = `${Math.min(i,j)}-${Math.max(i,j)}`;
        if (!seen.has(key)) { seen.add(key); edges.push({ a:i, b:j }); }
      });
  }
}

function resize() {
  const p = canvas.parentElement!;
  W = canvas.width  = p.offsetWidth;
  H = canvas.height = p.offsetHeight;
  if (W > 0 && H > 0) buildGraph();
}
window.addEventListener('resize', resize);

// cursor — listen on parent since canvas is pointer-events:none
canvas.parentElement!.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouse.x = e.clientX - r.left;
  mouse.y = e.clientY - r.top;
  mouse.active = true;
});
canvas.parentElement!.addEventListener('mouseleave', () => { mouse.active = false; });

function update(dt: number, now: number) {
  const ax = new Float32Array(N);
  const ay = new Float32Array(N);

  // repulsion between all node pairs
  for (let i = 0; i < N; i++) {
    for (let j = i+1; j < N; j++) {
      const dx = nodes[j].x-nodes[i].x, dy = nodes[j].y-nodes[i].y;
      const d2 = Math.max(dx*dx+dy*dy, 150);
      const d  = Math.sqrt(d2);
      const f  = REPEL_K / d2;
      ax[i] -= f*dx/d; ay[i] -= f*dy/d;
      ax[j] += f*dx/d; ay[j] += f*dy/d;
    }
  }

  // spring attraction along edges
  for (const e of edges) {
    const dx = nodes[e.b].x-nodes[e.a].x, dy = nodes[e.b].y-nodes[e.a].y;
    const d  = Math.sqrt(dx*dx+dy*dy) || 1;
    const f  = SPRING_K * (d - REST_LEN);
    ax[e.a] += f*dx/d; ay[e.a] += f*dy/d;
    ax[e.b] -= f*dx/d; ay[e.b] -= f*dy/d;
  }

  // soft boundary walls
  const xMin=W*ZONE_L, xMax=W*ZONE_R, yMin=H*ZONE_T, yMax=H*ZONE_B;
  for (let i = 0; i < N; i++) {
    const n = nodes[i];
    if (n.x < xMin) ax[i] += BOUND_K*(xMin-n.x);
    if (n.x > xMax) ax[i] += BOUND_K*(xMax-n.x);
    if (n.y < yMin) ay[i] += BOUND_K*(yMin-n.y);
    if (n.y > yMax) ay[i] += BOUND_K*(yMax-n.y);
  }

  // cursor repulsion
  if (mouse.active) {
    for (let i = 0; i < N; i++) {
      const dx = nodes[i].x-mouse.x, dy = nodes[i].y-mouse.y;
      const d2 = dx*dx+dy*dy;
      if (d2 < CURSOR_R*CURSOR_R && d2 > 1) {
        const d = Math.sqrt(d2);
        const f = CURSOR_K / d2;
        ax[i] += f*dx/d; ay[i] += f*dy/d;
      }
    }
  }

  // integrate velocity + position
  for (let i = 0; i < N; i++) {
    const n = nodes[i];
    n.vx = (n.vx + ax[i]*dt) * DAMPING;
    n.vy = (n.vy + ay[i]*dt) * DAMPING;
    const spd = Math.sqrt(n.vx*n.vx+n.vy*n.vy);
    if (spd > MAX_SPD) { n.vx = n.vx/spd*MAX_SPD; n.vy = n.vy/spd*MAX_SPD; }
    n.x += n.vx; n.y += n.vy;
  }

  // advance signals, cull finished ones
  for (const s of signals) s.t += s.spd * dt;
  signals = signals.filter(s => s.t <= 1);

  // spawn new signal
  if (now > nextSignal && signals.length < 5 && edges.length > 0) {
    const e   = edges[Math.floor(Math.random()*edges.length)];
    const fwd = Math.random() > 0.5;
    signals.push({ a: fwd?e.a:e.b, b: fwd?e.b:e.a, t: 0, spd: 0.022 + Math.random()*0.018 });
    nextSignal = now + 1000 + Math.random()*2200;
  }

  // periodic random kick so the graph never goes totally still
  if (now > nextKick) {
    const i = Math.floor(Math.random()*N);
    const angle = Math.random()*Math.PI*2;
    nodes[i].vx += Math.cos(angle)*3.5;
    nodes[i].vy += Math.sin(angle)*3.5;
    nextKick = now + 5000 + Math.random()*5000;
  }
}

function draw() {
  ctx.clearRect(0, 0, W, H);

  const activeKeys = new Set(signals.map(s => `${Math.min(s.a,s.b)}-${Math.max(s.a,s.b)}`));

  // edges
  for (const e of edges) {
    const key = `${Math.min(e.a,e.b)}-${Math.max(e.a,e.b)}`;
    ctx.beginPath();
    ctx.moveTo(nodes[e.a].x, nodes[e.a].y);
    ctx.lineTo(nodes[e.b].x, nodes[e.b].y);
    ctx.strokeStyle = activeKeys.has(key) ? 'rgba(232,96,44,0.30)' : 'rgba(232,96,44,0.10)';
    ctx.lineWidth = 1;
    ctx.stroke();
  }

  // travelling signals
  for (const s of signals) {
    const na = nodes[s.a], nb = nodes[s.b];
    const x  = na.x + (nb.x-na.x)*s.t;
    const y  = na.y + (nb.y-na.y)*s.t;

    const glow = ctx.createRadialGradient(x,y,0,x,y,16);
    glow.addColorStop(0, 'rgba(232,96,44,0.55)');
    glow.addColorStop(1, 'rgba(232,96,44,0)');
    ctx.fillStyle = glow;
    ctx.beginPath(); ctx.arc(x, y, 16, 0, Math.PI*2); ctx.fill();

    ctx.beginPath(); ctx.arc(x, y, 2.5, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(255,215,170,1)';
    ctx.fill();
  }

  // nodes
  for (const n of nodes) {
    const glow = ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,16);
    glow.addColorStop(0, 'rgba(232,96,44,0.30)');
    glow.addColorStop(1, 'rgba(232,96,44,0)');
    ctx.fillStyle = glow;
    ctx.beginPath(); ctx.arc(n.x, n.y, 16, 0, Math.PI*2); ctx.fill();

    ctx.beginPath(); ctx.arc(n.x, n.y, 3.5, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(232,96,44,0.92)';
    ctx.fill();
  }
}

function loop(now: number) {
  if (!running) return;
  const dt = Math.min((now-lastTime)/16.67, 3);
  lastTime = now;
  if (W > 0 && H > 0 && nodes.length > 0) { update(dt, now); draw(); }
  requestAnimationFrame(loop);
}

function start() {
  resize();
  if (W === 0 || H === 0) { requestAnimationFrame(start as any); return; }
  nextSignal = performance.now() + 800;
  nextKick   = performance.now() + 6000;
  lastTime   = performance.now();
  requestAnimationFrame(loop);
}

requestAnimationFrame(start as any);
window.addEventListener('beforeunload', () => { running = false; }, { once: true });
</script>

<style>
  @media (max-width: 640px) {
    #topology-canvas { display: none; }
  }
</style>
