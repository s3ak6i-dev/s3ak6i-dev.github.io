---
const GITHUB_USER = 's3ak6i-dev';
---

<div class="gh-widget">
  <div class="gh-section-title">GitHub Activity</div>

  <div class="gh-grid">
    <div class="gh-card">
      <div class="gh-card-header">
        <span class="gh-card-label">OWN PROJECTS</span>
        <span class="gh-dot"></span>
      </div>
      <ul class="gh-feed" id="gh-own-feed">
        <li class="gh-skeleton"></li>
        <li class="gh-skeleton"></li>
        <li class="gh-skeleton"></li>
      </ul>
      <canvas class="gh-heatmap" id="gh-own-heatmap"></canvas>
      <div class="gh-stats" id="gh-own-stats">&nbsp;</div>
    </div>

    <div class="gh-card">
      <div class="gh-card-header">
        <span class="gh-card-label">OPEN SOURCE</span>
        <span class="gh-dot"></span>
      </div>
      <ul class="gh-feed" id="gh-oss-feed">
        <li class="gh-skeleton"></li>
        <li class="gh-skeleton"></li>
        <li class="gh-skeleton"></li>
      </ul>
      <canvas class="gh-heatmap" id="gh-oss-heatmap"></canvas>
      <div class="gh-stats" id="gh-oss-stats">&nbsp;</div>
    </div>
  </div>
</div>

<style>
  .gh-widget {
    margin-top: 3rem;
  }

  /* identical to .card-label — same font, size, spacing, color */
  .gh-section-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 2rem 0 1rem;
    opacity: 0.5;
  }

  .gh-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .gh-grid { grid-template-columns: 1fr; }
  }

  .gh-card {
    border: 1px solid var(--border);
    border-top: 2px solid var(--accent);
    border-radius: 8px;
    padding: 1.5rem 1.5rem 1.75rem;
    background: #141414;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .gh-card:hover {
    border-color: rgba(232, 96, 44, 0.5);
    border-top-color: var(--accent);
    box-shadow: 0 4px 24px rgba(232, 96, 44, 0.06);
  }

  .gh-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .gh-card-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .gh-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    animation: gh-pulse 2s ease-in-out infinite;
  }

  @keyframes gh-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.2; }
  }

  .gh-feed {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    min-height: 80px;
  }

  /* skeletons are in the template so scoped styles work fine here */
  .gh-skeleton {
    height: 26px;
    background: linear-gradient(90deg, #1e1e1e 25%, #252525 50%, #1e1e1e 75%);
    background-size: 200% 100%;
    border-radius: 3px;
    animation: gh-shimmer 1.4s infinite;
    margin-bottom: 4px;
  }

  @keyframes gh-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .gh-heatmap {
    display: block;
    margin-bottom: 0.75rem;
  }

  .gh-stats {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-muted);
    opacity: 0.4;
  }
</style>

<script define:vars={{ GITHUB_USER }}>
(async () => {
  const ACCENT = [232, 96, 44];
  const WEEKS  = 26;
  const DAYS   = 7;
  const CELL   = 10;
  const GAP    = 2;

  // Inline styles for JS-injected elements — avoids Astro scoping issues entirely
  const S = {
    li:    'display:flex;align-items:baseline;gap:0.5rem;font-size:0.9rem;padding:0.6rem 0;border-bottom:1px solid rgba(255,255,255,0.05);list-style:none;',
    liEnd: 'display:flex;align-items:baseline;gap:0.5rem;font-size:0.9rem;padding:0.6rem 0;list-style:none;',
    dash:  'color:var(--accent);font-size:0.75rem;flex-shrink:0;',
    event: 'color:rgba(255,255,255,0.35);',
    repo:  'color:rgba(255,255,255,0.55);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;',
    time:  'margin-left:auto;font-family:JetBrains Mono,monospace;font-size:11px;color:rgba(255,255,255,0.18);flex-shrink:0;white-space:nowrap;',
  };

  function timeAgo(dateStr) {
    const diff = (Date.now() - new Date(dateStr)) / 1000;
    if (diff < 3600)  return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    return Math.floor(diff / 86400) + 'd ago';
  }

  function eventLabel(e) {
    switch (e.type) {
      case 'PushEvent':         return `pushed ${e.payload?.commits?.length ?? 1}`;
      case 'PullRequestEvent':  return `PR ${e.payload?.action ?? 'opened'}`;
      case 'IssuesEvent':       return `issue ${e.payload?.action ?? 'opened'}`;
      case 'ForkEvent':         return 'forked';
      case 'WatchEvent':        return 'starred';
      case 'CreateEvent':       return `created ${e.payload?.ref_type ?? 'repo'}`;
      case 'IssueCommentEvent': return 'commented';
      default:                  return e.type.replace('Event', '').toLowerCase();
    }
  }

  function renderFeed(id, events, isOwn) {
    const ul = document.getElementById(id);
    if (!ul) return;
    if (!events.length) {
      ul.innerHTML = `<li style="${S.liEnd}"><span style="${S.dash}">—</span><span style="${S.event}">no recent activity</span></li>`;
      return;
    }
    ul.innerHTML = events.slice(0, 3).map((e, i) => {
      const repo    = isOwn ? e.repo.name.split('/')[1] : e.repo.name;
      const isLast  = i === Math.min(events.length, 3) - 1;
      return `<li style="${isLast ? S.liEnd : S.li}">
        <span style="${S.dash}">—</span>
        <span style="${S.event}">${eventLabel(e)}</span>
        <span style="${S.repo}">${repo}</span>
        <span style="${S.time}">${timeAgo(e.created_at)}</span>
      </li>`;
    }).join('');
  }

  function eventsToBuckets(events) {
    const total   = WEEKS * DAYS;
    const buckets = new Array(total).fill(0);
    const now     = Date.now();
    for (const e of events) {
      const ageDays = (now - new Date(e.created_at)) / 86400000;
      const slot    = Math.floor(ageDays);
      if (slot < total) buckets[(total - 1) - slot]++;
    }
    return buckets;
  }

  function drawHeatmap(canvasId, buckets) {
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;

    const dpr = window.devicePixelRatio || 1;
    const W   = WEEKS * CELL + (WEEKS - 1) * GAP;
    const H   = DAYS  * CELL + (DAYS  - 1) * GAP;

    canvas.style.width  = W + 'px';
    canvas.style.height = H + 'px';
    canvas.width        = W * dpr;
    canvas.height       = H * dpr;

    const ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);

    const max = Math.max(...buckets, 1);

    for (let w = 0; w < WEEKS; w++) {
      for (let d = 0; d < DAYS; d++) {
        const val   = buckets[w * DAYS + d] ?? 0;
        const alpha = val === 0 ? 0.07 : 0.18 + (val / max) * 0.82;
        const x     = w * (CELL + GAP);
        const y     = d * (CELL + GAP);
        ctx.fillStyle = `rgba(${ACCENT[0]},${ACCENT[1]},${ACCENT[2]},${alpha})`;
        ctx.beginPath();
        ctx.roundRect(x, y, CELL, CELL, 2);
        ctx.fill();
      }
    }
  }

  try {
    const res = await fetch(
      `https://api.github.com/users/${GITHUB_USER}/events/public?per_page=100`
    );
    if (!res.ok) throw new Error('api error');
    const events = await res.json();

    const own = events.filter(e =>  e.repo.name.startsWith(`${GITHUB_USER}/`));
    const oss = events.filter(e => !e.repo.name.startsWith(`${GITHUB_USER}/`));

    renderFeed('gh-own-feed', own, true);
    renderFeed('gh-oss-feed', oss, false);

    drawHeatmap('gh-own-heatmap', eventsToBuckets(own));
    drawHeatmap('gh-oss-heatmap', eventsToBuckets(oss));

    const ownCommits = own
      .filter(e => e.type === 'PushEvent')
      .reduce((n, e) => n + (e.payload?.commits?.length ?? 1), 0);
    const ossRepos = new Set(oss.map(e => e.repo.name)).size;
    const ossPRs   = oss.filter(e => e.type === 'PullRequestEvent').length;

    const ownEl = document.getElementById('gh-own-stats');
    const ossEl = document.getElementById('gh-oss-stats');
    if (ownEl) ownEl.textContent = `${own.length} events · ${ownCommits} commits`;
    if (ossEl) ossEl.textContent = `${ossPRs} PRs · ${ossRepos} repo${ossRepos !== 1 ? 's' : ''}`;
  } catch {
    ['gh-own-feed', 'gh-oss-feed'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.innerHTML = `<li style="${S.liEnd}"><span style="${S.dash}">—</span><span style="${S.event}">could not load activity</span></li>`;
    });
  }
})();
</script>
