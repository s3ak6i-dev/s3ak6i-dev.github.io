---
---

<!-- Secret overlay -->
<div class="secret-overlay" id="secret-overlay" aria-hidden="true">

  <!-- "You found it" screen -->
  <div class="secret-found" id="secret-found">
    <p class="secret-label">&gt;_ secret unlocked</p>
    <img
      class="secret-gif"
      src="https://media1.tenor.com/m/g81kFMWk7hAAAAAd/bye.gif"
      alt="Truman waving goodbye"
    />
    <h2 class="secret-title">you found it.</h2>
    <p class="secret-sub">not many do.</p>
    <button class="secret-play" id="secret-play">play breakout →</button>
    <button class="secret-close" id="secret-close-found">✕ close</button>
  </div>

  <!-- Breakout game screen -->
  <div class="secret-game" id="secret-game">
    <div class="game-header">
      <span class="game-label">&gt;_ breakout</span>
      <span class="game-score">score: <span id="game-score">0</span></span>
      <button class="secret-close" id="secret-close-game">✕ close</button>
    </div>
    <canvas id="breakout-canvas"></canvas>
    <p class="game-hint" id="game-hint">move mouse or ← → to control</p>
  </div>

</div>

<style>
  .secret-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(6px);
    z-index: 2000;
    align-items: center;
    justify-content: center;
  }

  .secret-overlay.open {
    display: flex;
  }

  /* Found screen */
  .secret-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .secret-game {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .secret-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin: 0;
  }

  .secret-gif {
    width: 220px;
    border-radius: 6px;
  }

  .secret-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text);
    margin: 0;
  }

  .secret-sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--text-muted);
    margin: 0;
  }

  .secret-play {
    margin-top: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--accent);
    background: rgba(232,96,44,0.08);
    border: 1px solid var(--accent);
    border-radius: 4px;
    padding: 0.6rem 1.5rem;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .secret-play:hover {
    background: var(--accent);
    color: #0d0d0d;
  }

  .secret-close {
    background: none;
    border: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: rgba(255,255,255,0.2);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    transition: color 0.2s;
  }

  .secret-close:hover { color: var(--text-muted); }

  /* Game */
  .game-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
    max-width: 480px;
  }

  .game-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--accent);
    flex: 1;
  }

  .game-score {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--text-muted);
  }

  #breakout-canvas {
    border: 1px solid var(--border);
    border-radius: 6px;
    display: block;
  }

  .game-hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: rgba(255,255,255,0.2);
    margin: 0;
  }
</style>

<script>
  const KONAMI = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
  let seq: string[] = [];

  document.addEventListener('keydown', e => {
    seq.push(e.key);
    if (seq.length > KONAMI.length) seq.shift();
    if (JSON.stringify(seq) === JSON.stringify(KONAMI)) openSecret();
  });

  const overlay     = document.getElementById('secret-overlay')!;
  const foundScreen = document.getElementById('secret-found')!;
  const gameScreen  = document.getElementById('secret-game')!;

  function openSecret() {
    overlay.classList.add('open');
    foundScreen.style.display = 'flex';
    gameScreen.style.display  = 'none';
    seq = [];
  }

  function closeSecret() {
    overlay.classList.remove('open');
    stopGame();
  }

  document.getElementById('secret-close-found')!.addEventListener('click', closeSecret);
  document.getElementById('secret-close-game')!.addEventListener('click', closeSecret);
  document.getElementById('secret-play')!.addEventListener('click', () => {
    foundScreen.style.display = 'none';
    gameScreen.style.display  = 'flex';
    startGame();
  });

  overlay.addEventListener('click', e => {
    if (e.target === overlay) closeSecret();
  });

  // ── Breakout ──────────────────────────────────────────────────────────────
  const COLS = 8, ROWS = 5;
  const ACCENT_RGB = '232,96,44';
  let raf: number | null = null;

  function stopGame() {
    if (raf) { cancelAnimationFrame(raf); raf = null; }
  }

  function startGame() {
    stopGame();
    const canvas  = document.getElementById('breakout-canvas') as HTMLCanvasElement;
    const scoreEl = document.getElementById('game-score')!;
    const hintEl  = document.getElementById('game-hint')!;

    const W = Math.min(480, window.innerWidth - 48);
    const H = Math.round(W * 0.65);
    canvas.width  = W;
    canvas.height = H;
    canvas.style.width  = W + 'px';
    canvas.style.height = H + 'px';

    const ctx = canvas.getContext('2d')!;

    const PAD_W  = W * 0.18;
    const PAD_H  = 8;
    const BALL_R = 6;
    const GAP    = 6;
    const BRICK_W = (W - GAP * (COLS + 1)) / COLS;
    const BRICK_H = 14;
    const BRICK_TOP = 40;

    let padX   = W / 2 - PAD_W / 2;
    let ballX  = W / 2;
    let ballY  = H - 60;
    let speedX = (Math.random() > 0.5 ? 1 : -1) * (W * 0.004);
    let speedY = -(H * 0.007);
    let score  = 0;
    let lives  = 3;
    let state: 'playing' | 'won' | 'lost' = 'playing';

    // bricks[row][col] = alive
    const bricks = Array.from({ length: ROWS }, (_, r) =>
      Array.from({ length: COLS }, () => true)
    );

    // mouse control
    canvas.addEventListener('mousemove', e => {
      const rect = canvas.getBoundingClientRect();
      padX = e.clientX - rect.left - PAD_W / 2;
    });

    // keyboard control
    const keys: Record<string, boolean> = {};
    window.addEventListener('keydown', e => { keys[e.key] = true; });
    window.addEventListener('keyup',   e => { keys[e.key] = false; });

    hintEl.textContent = `move mouse or ← → to control · lives: ${lives}`;
    scoreEl.textContent = '0';

    function draw() {
      ctx.clearRect(0, 0, W, H);

      // bricks
      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS; c++) {
          if (!bricks[r][c]) continue;
          const alpha = 0.4 + (ROWS - r) / ROWS * 0.6;
          ctx.fillStyle = `rgba(${ACCENT_RGB},${alpha})`;
          const bx = GAP + c * (BRICK_W + GAP);
          const by = BRICK_TOP + r * (BRICK_H + GAP);
          ctx.beginPath();
          ctx.roundRect(bx, by, BRICK_W, BRICK_H, 3);
          ctx.fill();
        }
      }

      // paddle
      padX = Math.max(0, Math.min(W - PAD_W, padX));
      ctx.fillStyle = `rgba(${ACCENT_RGB},0.9)`;
      ctx.beginPath();
      ctx.roundRect(padX, H - PAD_H - 12, PAD_W, PAD_H, 4);
      ctx.fill();

      // ball
      ctx.beginPath();
      ctx.arc(ballX, ballY, BALL_R, 0, Math.PI * 2);
      ctx.fillStyle = '#E8E6E1';
      ctx.fill();

      // state messages
      if (state !== 'playing') {
        ctx.fillStyle = 'rgba(0,0,0,0.6)';
        ctx.fillRect(0, 0, W, H);
        ctx.fillStyle = '#E8E6E1';
        ctx.font = `bold ${W * 0.06}px Space Grotesk, sans-serif`;
        ctx.textAlign = 'center';
        ctx.fillText(state === 'won' ? 'you win.' : 'game over.', W/2, H/2 - 20);
        ctx.font = `${W * 0.035}px JetBrains Mono, monospace`;
        ctx.fillStyle = 'rgba(232,96,44,0.8)';
        ctx.fillText(`score: ${score}`, W/2, H/2 + 16);
        ctx.fillStyle = 'rgba(255,255,255,0.3)';
        ctx.font = `${W * 0.028}px JetBrains Mono, monospace`;
        ctx.fillText('press R to restart', W/2, H/2 + 44);
        ctx.textAlign = 'left';
      }
    }

    function update() {
      if (state !== 'playing') return;

      // keyboard paddle
      const speed = W * 0.012;
      if (keys['ArrowLeft'])  padX -= speed;
      if (keys['ArrowRight']) padX += speed;
      padX = Math.max(0, Math.min(W - PAD_W, padX));

      ballX += speedX;
      ballY += speedY;

      // wall collisions
      if (ballX - BALL_R < 0)  { ballX = BALL_R;      speedX =  Math.abs(speedX); }
      if (ballX + BALL_R > W)  { ballX = W - BALL_R;  speedX = -Math.abs(speedX); }
      if (ballY - BALL_R < 0)  { ballY = BALL_R;      speedY =  Math.abs(speedY); }

      // paddle collision
      if (
        ballY + BALL_R >= H - PAD_H - 12 &&
        ballY + BALL_R <= H - 12 &&
        ballX >= padX && ballX <= padX + PAD_W
      ) {
        speedY = -Math.abs(speedY);
        const hit = (ballX - padX) / PAD_W - 0.5;
        speedX = hit * W * 0.008;
        ballY  = H - PAD_H - 12 - BALL_R;
      }

      // fell off bottom
      if (ballY - BALL_R > H) {
        lives--;
        hintEl.textContent = `move mouse or ← → to control · lives: ${lives}`;
        if (lives <= 0) { state = 'lost'; return; }
        ballX = W / 2; ballY = H - 80;
        speedX = (Math.random() > 0.5 ? 1 : -1) * (W * 0.004);
        speedY = -(H * 0.007);
      }

      // brick collisions
      let remaining = 0;
      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS; c++) {
          if (!bricks[r][c]) continue;
          remaining++;
          const bx = GAP + c * (BRICK_W + GAP);
          const by = BRICK_TOP + r * (BRICK_H + GAP);
          if (ballX + BALL_R > bx && ballX - BALL_R < bx + BRICK_W &&
              ballY + BALL_R > by && ballY - BALL_R < by + BRICK_H) {
            bricks[r][c] = false;
            remaining--;
            score += 10;
            scoreEl.textContent = String(score);
            const overlapL = ballX + BALL_R - bx;
            const overlapR = bx + BRICK_W - (ballX - BALL_R);
            const overlapT = ballY + BALL_R - by;
            const overlapB = by + BRICK_H - (ballY - BALL_R);
            if (Math.min(overlapL, overlapR) < Math.min(overlapT, overlapB)) speedX *= -1;
            else speedY *= -1;
          }
        }
      }
      if (remaining === 0) state = 'won';
    }

    // restart
    const restartHandler = (e: KeyboardEvent) => {
      if (e.key === 'r' || e.key === 'R') {
        window.removeEventListener('keydown', restartHandler as any);
        startGame();
      }
    };
    window.addEventListener('keydown', restartHandler as any);

    function loop() {
      update();
      draw();
      raf = requestAnimationFrame(loop);
    }
    loop();
  }
</script>
